<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="gambatta.tn.ui.ActiviteBackController"
            styleClass="root" stylesheets="@style.css">

    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #1e293b; -fx-padding: 15 30 15 30; -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">
            <Button text="🚪 Déconnexion" onAction="#handleLogout" styleClass="btn-secondary" style="-fx-text-fill: #ff4757; -fx-border-color: rgba(255,71,87,0.5);"/>
            <Label text="GAMBATTA - ADMIN DASHBOARD" styleClass="title" style="-fx-font-size: 24px;"/>
        </HBox>
    </top>

    <center>
        <TabPane>
            <!-- TAB 1: ACTIVITES -->
            <Tab text="Gestion Activités" closable="false">
                <ScrollPane fitToWidth="true" style="-fx-background-color: #050b14; -fx-background: #050b14;">
                    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #050b14;">
                        
                        <!-- CARD HEADER MATCHING SCREENSHOT -->
                        <VBox style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 5);" spacing="20">
                            
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="5">
                                    <Label text="Registre des Activités" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                                    <Label text="Interface Administrative Gambatta" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <HBox spacing="15" alignment="CENTER">
                                    <Button text="📄" styleClass="btn-icon" onAction="#exportActivitesPDF" style="-fx-background-color: #0f172a;"/>
                                    <Button text="📊" styleClass="btn-icon" style="-fx-background-color: #0f172a;"/>
                                    <Button text="+" styleClass="btn-primary" style="-fx-background-radius: 50%; -fx-min-width: 45px; -fx-min-height: 45px; -fx-font-size: 20px;" onAction="#toggleForm"/>
                                </HBox>
                            </HBox>
                            
                            <!-- SEARCH & FILTERS ROW -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <TextField fx:id="tfSearchActivites" promptText="Rechercher par nom, type..." 
                                           style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-background-radius: 20; -fx-pref-height: 45px; -fx-padding: 0 20;" HBox.hgrow="ALWAYS"/>
                                <Button text="🔍" styleClass="btn-icon" style="-fx-background-color: #0f172a; -fx-min-width: 45px; -fx-min-height: 45px;"/>
                                <Button text="🎤" onAction="#handleVoiceSearch" styleClass="btn-icon" style="-fx-background-color: #0f172a; -fx-min-width: 45px; -fx-min-height: 45px;"/>
                                <Button text="🗑" styleClass="btn-icon" style="-fx-background-color: #0f172a; -fx-min-width: 45px; -fx-min-height: 45px;"/>
                                <Region prefWidth="20"/>
                                <Button text="📅" styleClass="btn-icon" style="-fx-background-color: rgba(255,255,255,0.1); -fx-min-width: 40px; -fx-min-height: 40px;"/>
                                <Button text="≡" styleClass="btn-icon" style="-fx-background-color: rgba(255,255,255,0.1); -fx-min-width: 40px; -fx-min-height: 40px;"/>
                            </HBox>

                            <!-- TABLE AND FORM HBOX -->
                            <HBox spacing="20" VBox.vgrow="ALWAYS">
                                
                                <!-- TABLE VIEW -->
                                <TableView fx:id="tableActivites" styleClass="search-field" style="-fx-background-color: transparent; -fx-border-width: 0; -fx-fixed-cell-size: 65px; -fx-control-inner-background: transparent; -fx-table-cell-border-color: rgba(255,255,255,0.05);" prefHeight="600" HBox.hgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colActImage" text="IMAGE" prefWidth="120" style="-fx-alignment: CENTER;" />
                                        <TableColumn fx:id="colActNom" text="NOM" prefWidth="200" />
                                        <TableColumn fx:id="colActType" text="TYPE" prefWidth="200" />
                                        <TableColumn fx:id="colActDispo" text="DISPO" prefWidth="150" style="-fx-alignment: CENTER;" />
                                    </columns>
                                </TableView>

                                <!-- ALWAYS VISIBLE FORM FOR ADD/EDIT ON THE RIGHT -->
                                <VBox fx:id="vboxForm" spacing="10" prefWidth="350" styleClass="card" HBox.hgrow="NEVER">
                                    <Label text="Détails" styleClass="card-title"/>
                                    <VBox spacing="2">
                                        <TextField fx:id="tfActNom" promptText="Nom" styleClass="search-field"/>
                                        <Label fx:id="errActNom" text="[!] Nom requis." styleClass="error-label" visible="false" managed="false"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <TextField fx:id="tfActType" promptText="Type" styleClass="search-field"/>
                                        <Label fx:id="errActType" text="[!] Type requis." styleClass="error-label" visible="false" managed="false"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <TextField fx:id="tfActDispo" promptText="Disponibilité" styleClass="search-field"/>
                                        <Label fx:id="errActDispo" text="[!] Disponibilité requise." styleClass="error-label" visible="false" managed="false"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <TextField fx:id="tfActAdresse" promptText="Emplacement dans le complexe (ex: Terrain A)" styleClass="search-field"/>
                                        <Label fx:id="errActAdresse" text="[!] Emplacement requis." styleClass="error-label" visible="false" managed="false"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <TextArea fx:id="taActDesc" promptText="Description" prefRowCount="4" styleClass="search-field"/>
                                        <Label fx:id="errActDesc" text="[!] Description requise (Min 10 caractères)." styleClass="error-label" visible="false" managed="false"/>
                                    </VBox>
                                    
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <TextField fx:id="tfActImage" promptText="Image URL" editable="false" styleClass="search-field" HBox.hgrow="ALWAYS"/>
                                        <Button text="Parcourir" onAction="#handleSelectImage" styleClass="btn-secondary"/>
                                    </HBox>
                                    <ImageView fx:id="ivImagePreview" fitWidth="310" fitHeight="120" preserveRatio="false" />

                                    <HBox spacing="10" alignment="CENTER">
                                        <Button text="Ajouter" onAction="#addActivite" styleClass="btn-primary"/>
                                        <Button text="Modifier" onAction="#updateActivite" styleClass="btn-secondary"/>
                                        <Button text="Sup" onAction="#deleteActivite" styleClass="btn-secondary" style="-fx-text-fill: #ff4757;"/>
                                    </HBox>
                                    <Button text="🤖 Proposer par IA" onAction="#suggestActivitiesAI" prefWidth="Infinity" styleClass="btn-secondary" style="-fx-text-fill: #9c88ff; -fx-border-color: #9c88ff; -fx-margin-top: 10px;"/>
                                </VBox>
                                
                            </HBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- TAB 2: RULES -->
            <Tab text="Gestion Règles (Rules)" closable="false">
                <VBox spacing="10">
                    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10 20 0 20;">
                        <TextField fx:id="tfSearchRules" promptText="🔍 Rechercher Règle..." styleClass="search-field" prefWidth="300"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="📄 Exporter PDF" onAction="#exportRulesPDF" styleClass="btn-secondary"/>
                    </HBox>
                    <HBox spacing="20" style="-fx-padding: 10 20 20 20;" VBox.vgrow="ALWAYS">
                        <TableView fx:id="tableRules" HBox.hgrow="ALWAYS" styleClass="search-field">
                            <columns>
                                <TableColumn fx:id="colRuleAct" text="Activité" prefWidth="150" />
                                <TableColumn fx:id="colRuleDesc" text="Description" prefWidth="250" />
                            </columns>
                        </TableView>
                        <VBox spacing="10" prefWidth="300" styleClass="card">
                            <Label text="Règle" styleClass="card-title"/>
                            <VBox spacing="2">
                                <ComboBox fx:id="cbRuleActivite" promptText="Associer à l'activité..." prefWidth="Infinity" styleClass="search-field"/>
                                <Label fx:id="errRuleAct" text="[!] Activité requise." styleClass="error-label" visible="false" managed="false"/>
                            </VBox>
                            <VBox spacing="2">
                                <TextArea fx:id="taRuleDesc" promptText="Contenu de la règle" prefRowCount="4" styleClass="search-field"/>
                                <Label fx:id="errRuleDesc" text="[!] Contenu requis (Min 10 caractères)." styleClass="error-label" visible="false" managed="false"/>
                            </VBox>
                            <HBox spacing="10" alignment="CENTER">
                                <Button text="Ajouter" onAction="#addRule" styleClass="btn-primary"/>
                                <Button text="Modifier" onAction="#updateRule" styleClass="btn-secondary"/>
                                <Button text="Sup" onAction="#deleteRule" styleClass="btn-secondary" style="-fx-text-fill: red;"/>
                            </HBox>
                            <Button text="🤖 Générer Règle via IA" onAction="#suggestRuleAI" prefWidth="Infinity" styleClass="btn-secondary" style="-fx-text-fill: #9c88ff; -fx-border-color: #9c88ff; -fx-margin-top: 5px;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <!-- TAB 3: RESERVATIONS -->
            <Tab text="Validation Réservations" closable="false">
                <VBox spacing="10">
                    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10 20 0 20;">
                        <TextField fx:id="tfSearchReservations" promptText="🔍 Rechercher Réservation..." styleClass="search-field" prefWidth="300"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="📄 Exporter PDF" onAction="#exportReservationsPDF" styleClass="btn-secondary"/>
                    </HBox>
                    <HBox spacing="20" style="-fx-padding: 10 20 20 20;" VBox.vgrow="ALWAYS">
                        <TableView fx:id="tableReservations" HBox.hgrow="ALWAYS" styleClass="search-field">
                            <columns>
                                <TableColumn fx:id="colResAct" text="Activité" prefWidth="150" />
                                <TableColumn fx:id="colResClient" text="CLIENT" prefWidth="150" style="-fx-font-weight: bold; -fx-text-fill: #3b82f6;" />
                                <TableColumn fx:id="colResDate" text="Date" prefWidth="100" />
                                <TableColumn fx:id="colResHeure" text="Heure" prefWidth="100" />
                                <TableColumn fx:id="colResStatut" text="Statut" prefWidth="150" />
                            </columns>
                        </TableView>
                        <VBox spacing="20" prefWidth="300" styleClass="card" alignment="CENTER">
                            <Label text="Action Administrateur" styleClass="card-title"/>
                            <Button text="✅ VALIDER" onAction="#validerReservation" prefWidth="200" styleClass="btn-primary" style="-fx-background-color: #2ed573;"/>
                            <Button text="❌ REFUSER" onAction="#refuserReservation" prefWidth="200" styleClass="btn-secondary" style="-fx-border-color: #ff4757; -fx-text-fill: #ff4757;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <!-- TAB 4: STATISTIQUES -->
            <Tab text="📊 Dashboard &amp; KPIs" closable="false">
                <ScrollPane fitToWidth="true" style="-fx-background-color: #050b14; -fx-background: #050b14;">
                    <VBox spacing="30" style="-fx-padding: 40; -fx-background-color: #050b14;">
                        
                        <!-- KPI CARDS ROW -->
                        <HBox spacing="25" alignment="CENTER">
                            <VBox style="-fx-background-color: linear-gradient(to bottom right, #1e293b, #0f172a); -fx-padding: 25; -fx-background-radius: 15; -fx-min-width: 280; -fx-border-color: #3b82f6; -fx-border-width: 0 0 4 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                                <Label text="TOTAL ACTIVITÉS" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblTotalActs" text="0" style="-fx-text-fill: white; -fx-font-size: 42px; -fx-font-weight: bold;"/>
                                <Label text="Inscrites en base" style="-fx-text-fill: #3b82f6; -fx-font-size: 12px;"/>
                            </VBox>
                            
                            <VBox style="-fx-background-color: linear-gradient(to bottom right, #1e293b, #0f172a); -fx-padding: 25; -fx-background-radius: 15; -fx-min-width: 280; -fx-border-color: #f59e0b; -fx-border-width: 0 0 4 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                                <Label text="TOTAL RÉSERVATIONS" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblTotalRes" text="0" style="-fx-text-fill: white; -fx-font-size: 42px; -fx-font-weight: bold;"/>
                                <Label text="Toutes périodes confondues" style="-fx-text-fill: #f59e0b; -fx-font-size: 12px;"/>
                            </VBox>
                            
                            <VBox style="-fx-background-color: linear-gradient(to bottom right, #1e293b, #0f172a); -fx-padding: 25; -fx-background-radius: 15; -fx-min-width: 280; -fx-border-color: #10b981; -fx-border-width: 0 0 4 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                                <Label text="TOP ACTIVITÉ" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblTopAct" text="N/A" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-wrap-text: true;" prefHeight="60"/>
                                <Label text="La plus populaire" style="-fx-text-fill: #10b981; -fx-font-size: 12px;"/>
                            </VBox>
                        </HBox>
                        
                        <!-- CHARTS ROW -->
                        <HBox spacing="30" alignment="CENTER" VBox.vgrow="ALWAYS">
                            <VBox spacing="15" alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #1e293b; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);">
                                <Label text="RÉPARTITION PAR CATÉGORIE" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                                <javafx.scene.chart.PieChart fx:id="pieChartActivites" prefHeight="350" prefWidth="350" legendVisible="true" />
                            </VBox>
                            
                            <VBox spacing="15" alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #1e293b; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);">
                                <Label text="POPULARITÉ DES ACTIVITÉS" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                                <javafx.scene.chart.BarChart fx:id="barChartReservations" prefHeight="350" prefWidth="550" legendVisible="false">
                                    <xAxis><javafx.scene.chart.CategoryAxis tickLabelFill="white" fx:id="xAxisAct"/></xAxis>
                                    <yAxis><javafx.scene.chart.NumberAxis tickLabelFill="white" fx:id="yAxisRes"/></yAxis>
                                </javafx.scene.chart.BarChart>
                            </VBox>
                        </HBox>
                        
                        <Button text="🔄 ACTUALISER LE DASHBOARD" onAction="#refreshStats" prefWidth="Infinity" styleClass="btn-primary" style="-fx-background-radius: 12; -fx-font-weight: bold; -fx-font-size: 16px; -fx-min-height: 50;"/>
                    </VBox>
                </ScrollPane>
            </Tab>
        </TabPane>
    </center>

</BorderPane>
