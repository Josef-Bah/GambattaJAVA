<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding:30; -fx-background-color:#0f172a;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gambatta.tn.ui.buvette.DashboardController">

    <Label text=" Buvette Dashboard" style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:white;"/>
    <Separator/>

    <HBox spacing="20">
        <VBox style="-fx-background-color:#1e293b; -fx-padding:20; -fx-background-radius:10;" prefWidth="200">
            <Label text=" Total Revenue" style="-fx-text-fill:#94a3b8;"/>
            <Label fx:id="revenueLabel" text="..." style="-fx-font-size:20px; -fx-text-fill:#22c55e; -fx-font-weight:bold;"/>
        </VBox>
        <VBox style="-fx-background-color:#1e293b; -fx-padding:20; -fx-background-radius:10;" prefWidth="200">
            <Label text=" Top Product" style="-fx-text-fill:#94a3b8;"/>
            <Label fx:id="topProductLabel" text="..." style="-fx-font-size:18px; -fx-text-fill:#f59e0b; -fx-font-weight:bold;"/>
        </VBox>
    </HBox>

    <Label text=" Recent Sales" style="-fx-font-size:16px; -fx-text-fill:white;"/>
    <TableView fx:id="ventesTable" prefHeight="350"/>

</VBox>
