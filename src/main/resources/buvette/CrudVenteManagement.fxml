<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding:30; -fx-background-color:#0f172a;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gambatta.tn.ui.buvette.CrudVenteController">

    <!-- STATS HEADER -->
    <HBox spacing="20">
        <VBox style="-fx-background-color:#1e293b; -fx-padding:15; -fx-background-radius:10;" prefWidth="180">
            <Label text=" Total Ventes" style="-fx-text-fill:#94a3b8;"/>
            <Label fx:id="statTotal" text="..." style="-fx-font-size:18px; -fx-text-fill:#FFD700; -fx-font-weight:bold;"/>
        </VBox>
        <VBox style="-fx-background-color:#1e293b; -fx-padding:15; -fx-background-radius:10;" prefWidth="180">
            <Label text=" Revenue Total" style="-fx-text-fill:#94a3b8;"/>
            <Label fx:id="statRevenue" text="..." style="-fx-font-size:18px; -fx-text-fill:#22c55e; -fx-font-weight:bold;"/>
        </VBox>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text=" Gestion des Ventes" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search Amount/Date..." prefWidth="200" styleClass="search-field"/>
        <ComboBox fx:id="sortCombo" promptText="Trier par..." style="-fx-background-color:rgba(30, 41, 59, 0.8); -fx-text-fill:white;"/>
        <Button text="📊" onAction="#showStats" styleClass="btn-secondary"/>
        <Button text="Rapport" onAction="#exportPDF" styleClass="btn-secondary"/>
    </HBox>
    
    <Separator/>

    <!-- TABLE -->
    <TableView fx:id="venteTable" prefHeight="350" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colId"      text="Vente n°"  prefWidth="80"/>
            <TableColumn fx:id="colQuantv"  text="Quantité"  prefWidth="100"/>
            <TableColumn fx:id="colDatev"   text="Date"      prefWidth="200"/>
            <TableColumn fx:id="colMontantv" text="Montant (DT)" prefWidth="120"/>
            <TableColumn fx:id="colUserName" text="Nom Client"   prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="🗑️" onAction="#deleteVente" style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:10 20;"/>
        <Button text="🔄" onAction="#refresh" styleClass="btn-secondary"/>
    </HBox>

    <Label fx:id="statusLabel" text="" style="-fx-text-fill:#22c55e;"/>
</VBox>
