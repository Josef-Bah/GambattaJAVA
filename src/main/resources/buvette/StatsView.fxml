<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="20" style="-fx-padding:30; -fx-background-color:#0f172a;" prefWidth="800" prefHeight="600"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gambatta.tn.ui.buvette.StatsController">
    
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label fx:id="titleLabel" text="Statistiques Détaillées" style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Fermer" onAction="#close" styleClass="btn-secondary"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color:#1e293b; -fx-padding:15; -fx-background-radius:15;">
            <Label fx:id="pieTitle" text="Répartition" style="-fx-text-fill:#94a3b8; -fx-font-weight:bold;"/>
            <PieChart fx:id="pieChart" legendVisible="true" labelsVisible="true" VBox.vgrow="ALWAYS"/>
        </VBox>
        
        <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color:#1e293b; -fx-padding:15; -fx-background-radius:15;">
            <Label fx:id="barTitle" text="Analyse Temporelle" style="-fx-text-fill:#94a3b8; -fx-font-weight:bold;"/>
            <BarChart fx:id="barChart" VBox.vgrow="ALWAYS">
                <xAxis><CategoryAxis label="Catégorie" fx:id="xAxis"/></xAxis>
                <yAxis><NumberAxis label="Valeur" fx:id="yAxis"/></yAxis>
            </BarChart>
        </VBox>
    </HBox>
</VBox>
