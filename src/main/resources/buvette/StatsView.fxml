<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="25" style="-fx-padding:40; -fx-background-color: transparent;" prefWidth="900"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gambatta.tn.ui.buvette.StatsController">
    
    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5">
            <Label fx:id="titleLabel" text="Statistiques Gambatta" style="-fx-font-size:28px; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Label text="Analyse en temps réel de votre activité" style="-fx-text-fill:#64748b; -fx-font-size:14px;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" onAction="#close" style="-fx-background-color:rgba(255,255,255,0.05); -fx-text-fill:white; -fx-font-size:18px; -fx-background-radius:30; -fx-min-width:45; -fx-min-height:45; -fx-cursor:hand;"/>
    </HBox>

    <Separator style="-fx-opacity: 0.1;"/>

    <!-- KPI CARDS -->
    <HBox spacing="15" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color:rgba(255,255,255,0.03); -fx-padding:15; -fx-background-radius:15; -fx-border-color:rgba(255,255,255,0.05); -fx-border-radius:15;" HBox.hgrow="ALWAYS">
            <Label text="Ventes Totales" style="-fx-text-fill:#94a3b8; -fx-font-size:12px;"/>
            <Label fx:id="totalSalesLabel" text="-" style="-fx-text-fill:#FFD700; -fx-font-size:20px; -fx-font-weight:bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color:rgba(255,255,255,0.03); -fx-padding:15; -fx-background-radius:15; -fx-border-color:rgba(255,255,255,0.05); -fx-border-radius:15;" HBox.hgrow="ALWAYS">
            <Label text="Nombre de Produits" style="-fx-text-fill:#94a3b8; -fx-font-size:12px;"/>
            <Label fx:id="lowStockLabel" text="-" style="-fx-text-fill:#22c55e; -fx-font-size:20px; -fx-font-weight:bold;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-background:transparent; -fx-padding:0;" VBox.vgrow="ALWAYS">
        <VBox spacing="25">
            <!-- PIE CHART -->
            <VBox spacing="15" style="-fx-background-color:rgba(255,255,255,0.03); -fx-padding:20; -fx-background-radius:20; -fx-border-color:rgba(255,255,255,0.05); -fx-border-radius:20;">
                <Label fx:id="pieTitle" text="Répartition du Stock par Catégorie" style="-fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:16px;"/>
                <PieChart fx:id="pieChart" legendVisible="true" labelsVisible="false" prefHeight="250"/>
            </VBox>
            
            <!-- BAR CHART -->
            <VBox spacing="15" style="-fx-background-color:rgba(255,255,255,0.03); -fx-padding:20; -fx-background-radius:20; -fx-border-color:rgba(255,255,255,0.05); -fx-border-radius:20;">
                <Label fx:id="barTitle" text="Comparaison Analytique" style="-fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:16px;"/>
                <BarChart fx:id="barChart" prefHeight="280" legendVisible="false">
                    <xAxis><CategoryAxis tickLabelFill="#94a3b8" fx:id="xAxis" tickLabelRotation="45"/></xAxis>
                    <yAxis><NumberAxis tickLabelFill="#94a3b8" fx:id="yAxis"/></yAxis>
                </BarChart>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
