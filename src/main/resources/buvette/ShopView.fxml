<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.buvette.ShopController">
   
    <!-- MAIN CONTENT -->
    <VBox spacing="0" style="-fx-background-color:#f1f5f9;">
        
        <!-- HEADER BANNER -->
        <HBox alignment="CENTER_LEFT" prefHeight="150" style="-fx-background-color:#021b61; -fx-padding: 30; -fx-background-radius: 0 0 20 20;">
            <VBox spacing="10">
                <HBox alignment="BOTTOM_LEFT" spacing="5">
                    <Label text="La Buvette" style="-fx-text-fill:white; -fx-font-size:36px; -fx-font-weight:900; -fx-font-family:'Segoe UI';"/>
                    <Circle fill="#FFD700" radius="4" translateY="-8"/>
                </HBox>
                <Label text="Équipez-vous et reprenez des forces avec nos produits sélectionnés." style="-fx-text-fill:#cbd5e1; -fx-font-size:14px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnToggleCart" onAction="#toggleCart" style="-fx-background-color:white; -fx-background-radius:20; -fx-padding: 10 20; -fx-font-weight:bold; -fx-text-fill:#021b61;" text="🛒 Panier">
               <graphic>
                   <Label fx:id="cartBadge" style="-fx-background-color:#FFD700; -fx-text-fill:#021b61; -fx-font-size:10px; -fx-padding: 2 6; -fx-background-radius:10;" text="0" translateY="-10" translateX="5"/>
               </graphic>
            </Button>
        </HBox>

        <!-- FILTERS -->
        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 30 0 20 0;">
            <HBox alignment="CENTER_LEFT" style="-fx-background-color:white; -fx-background-radius:10; -fx-padding:5 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);" prefWidth="300">
                <Label text="🔍" style="-fx-text-fill:#94a3b8;"/>
                <TextField fx:id="searchField" promptText="Rechercher un produit..." style="-fx-background-color:transparent; -fx-border-color:transparent;" prefWidth="250"/>
            </HBox>
            <ComboBox fx:id="sortCombo" promptText="Trier par..." style="-fx-background-color:white; -fx-background-radius:10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);" prefWidth="200"/>
            <VBox>
                <ComboBox fx:id="deviseCombo" promptText="Devise: TND" style="-fx-background-color:white; -fx-background-radius:10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);" prefWidth="200"/>
                <Label text="Prix affichés en devise locale." style="-fx-text-fill:#94a3b8; -fx-font-size:10px; -fx-padding: 2 0 0 5;"/>
            </VBox>
        </HBox>

        <!-- AI SUGGESTIONS SECTION -->
        <VBox fx:id="aiSuggestionsContainer" spacing="15" style="-fx-padding: 10 50 20 50;" visible="false" managed="false">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Nos recommandations IA pour vous ✨" style="-fx-text-fill:#021b61; -fx-font-size:20px; -fx-font-weight:bold;"/>
                <Label text="Basé sur votre panier" style="-fx-text-fill:#64748b; -fx-font-size:13px; -fx-font-style:italic;"/>
            </HBox>
            <ScrollPane minHeight="240" prefHeight="240" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding: 5 0;">
                <content>
                    <HBox fx:id="aiSuggestionsHBox" spacing="25" alignment="CENTER_LEFT" style="-fx-padding: 10 5;" minHeight="200"/>
                </content>
            </ScrollPane>
            <Separator prefWidth="200" style="-fx-opacity: 0.2;"/>
        </VBox>

        <!-- PRODUCTS GRID -->
        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="30" left="50" right="50" top="10"/></padding>
            <FlowPane fx:id="productsFlowPane" hgap="30" vgap="30" alignment="CENTER"/>
        </ScrollPane>

    </VBox>

    <!-- DIM OVERLAY (Invisible by default) -->
    <Region fx:id="dimOverlay" style="-fx-background-color:rgba(0,0,0,0.5);" visible="false" onMouseClicked="#toggleCart"/>

    <!-- PANIER SIDEBAR -->
    <VBox fx:id="cartSidebar" alignment="TOP_CENTER" maxWidth="350" minWidth="350" style="-fx-background-color:white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, -5, 0);" translateX="400" StackPane.alignment="CENTER_RIGHT">
        
        <Label text="Votre panier est vide." fx:id="emptyCartLabel" style="-fx-text-fill:#94a3b8; -fx-font-size:16px; -fx-padding:30;"/>
        
        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;" VBox.vgrow="ALWAYS">
            <VBox fx:id="cartItemsContainer" spacing="15" style="-fx-padding:20;"/>
        </ScrollPane>

        <VBox spacing="15" style="-fx-background-color:#f8fafc; -fx-padding:20; -fx-border-color:#e2e8f0; -fx-border-width:1 0 0 0;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Total estimé" style="-fx-text-fill:#64748b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalLabel" text="0.00 TND" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#0284c7;"/>
            </HBox>
            <Button text="Commander maintenant" onAction="#checkout" maxWidth="Infinity" style="-fx-background-color:#1e293b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:20; -fx-padding:15; -fx-font-size:14px;"/>
        </VBox>

    </VBox>

</StackPane>
