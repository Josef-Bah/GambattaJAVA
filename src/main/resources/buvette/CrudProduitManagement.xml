<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding:30; -fx-background-color:#0f172a;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gambatta.tn.ui.buvette.CrudProduitController">

    <!-- STATS HEADER -->
    <HBox spacing="20">
        <VBox style="-fx-background-color:#1e293b; -fx-padding:15; -fx-background-radius:10;" prefWidth="180">
            <Label text=" Total Produits" style="-fx-text-fill:#94a3b8;"/>
            <Label fx:id="statTotal" text="..." style="-fx-font-size:18px; -fx-text-fill:#FFD700; -fx-font-weight:bold;"/>
        </VBox>
        <VBox style="-fx-background-color:#1e293b; -fx-padding:15; -fx-background-radius:10;" prefWidth="180">
            <Label text=" Stock Total" style="-fx-text-fill:#94a3b8;"/>
            <Label fx:id="statStock" text="..." style="-fx-font-size:18px; -fx-text-fill:#22c55e; -fx-font-weight:bold;"/>
        </VBox>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text=" Produit Management" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search..." prefWidth="200" styleClass="search-field"/>
        <ComboBox fx:id="sortCombo" promptText="Trier par..." style="-fx-background-color:rgba(30, 41, 59, 0.8); -fx-text-fill:white;"/>
        <Button text="📄 Export PDF" onAction="#exportPDF" styleClass="btn-secondary"/>
    </HBox>
    
    <Separator/>

    <!-- TABLE -->
    <TableView fx:id="produitTable" prefHeight="300" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colId"    text="ID"        prefWidth="60"/>
            <TableColumn fx:id="colNom"   text="Nom"       prefWidth="160"/>
            <TableColumn fx:id="colDesc"  text="Desc"      prefWidth="200"/>
            <TableColumn fx:id="colPrix"  text="Prix"      prefWidth="100"/>
            <TableColumn fx:id="colStock" text="Stock"     prefWidth="80"/>
            <TableColumn fx:id="colRef"   text="Ref"       prefWidth="80"/>
        </columns>
    </TableView>

    <!-- FORM -->
    <HBox spacing="10">
        <TextField fx:id="fieldNom"   promptText="Nom"         prefWidth="130"/>
        <TextField fx:id="fieldDesc"  promptText="Description" prefWidth="160"/>
        <TextField fx:id="fieldPrix"  promptText="Prix"        prefWidth="80"/>
        <TextField fx:id="fieldStock" promptText="Stock"       prefWidth="70"/>
        <TextField fx:id="fieldRef"   promptText="Référence"   prefWidth="90"/>
    </HBox>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="🖼️ Choisir une Image" onAction="#chooseImage" styleClass="btn-secondary"/>
        <Label fx:id="imageNameLabel" text="Aucune image sélectionnée" style="-fx-text-fill:#94a3b8;"/>
    </HBox>

    <HBox spacing="10">
        <Button text="➕ Add"    onAction="#addProduit" styleClass="btn-primary"/>
        <Button text="✏️ Update" onAction="#updateProduit" styleClass="btn-secondary"/>
        <Button text="🗑️ Delete" onAction="#deleteProduit" style="-fx-background-color:#ef4444; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;"/>
        <Button text="🔄 Refresh" onAction="#refresh" styleClass="btn-secondary"/>
    </HBox>

    <Label fx:id="statusLabel" text="" style="-fx-text-fill:#22c55e;"/>
</VBox>
