<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #020617;" 
           stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" 
           xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="gambatta.tn.ui.buvette.SelectionController">
    
    <!-- BACKGROUND GRADIENT / IMAGE OVERLAY -->
    <Region style="-fx-background-color: linear-gradient(to bottom right, rgba(15, 23, 42, 0.9), rgba(2, 6, 23, 1));"/>

    <VBox alignment="CENTER" spacing="40">
        <!-- HEADER -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="Bienvenue sur GAMBATTA" style="-fx-font-size: 42px; -fx-font-weight: 900; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, #FFD700, 10, 0.5, 0, 0);"/>
            <Label text="Veuillez sélectionner votre espace de connexion" style="-fx-font-size: 18px; -fx-text-fill: #94a3b8;"/>
        </VBox>

        <HBox alignment="CENTER" spacing="50">
            <!-- CLIENT CARD -->
            <VBox alignment="TOP_CENTER" prefHeight="400" prefWidth="320" spacing="25" 
                  style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 15, 0, 0, 10);">
                <Label text="👤" style="-fx-font-size: 80px; -fx-text-fill: #38bdf8;"/>
                <VBox alignment="CENTER" spacing="5">
                    <Label text="ESPACE CLIENT" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Réserver des activités, consulter le catalogue" style="-fx-text-fill: #64748b; -fx-text-alignment: center; -fx-wrap-text: true;" maxWidth="200"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <Button onAction="#handleUserAccess" prefHeight="50" prefWidth="220" 
                        style="-fx-background-color: linear-gradient(to right, #f59e0b, #fbbf24); -fx-text-fill: #020617; -fx-font-weight: bold; -fx-background-radius: 12;" text="Connexion User" />
            </VBox>

            <!-- ADMIN CARD -->
            <VBox alignment="TOP_CENTER" prefHeight="400" prefWidth="320" spacing="25" 
                  style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 15, 0, 0, 10);">
                <Label text="⚙️" style="-fx-font-size: 80px; -fx-text-fill: #FFD700;"/>
                <VBox alignment="CENTER" spacing="5">
                    <Label text="ESPACE ADMIN" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Gérer les activités, valider les réservations" style="-fx-text-fill: #64748b; -fx-text-alignment: center; -fx-wrap-text: true;" maxWidth="200"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <Button onAction="#handleAdminAccess" prefHeight="50" prefWidth="220" 
                        style="-fx-background-color: transparent; -fx-border-color: #FFD700; -fx-border-radius: 12; -fx-text-fill: #FFD700; -fx-font-weight: bold;" text="Connexion Admin" />
            </VBox>
        </HBox>
    </VBox>
</StackPane>
