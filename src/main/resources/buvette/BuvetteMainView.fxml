<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gambatta.tn.ui.buvette.BuvetteMainController"
            prefHeight="650" prefWidth="1100"
            stylesheets="@style.css">

    <!-- TOP NAVIGATION BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color:#020617; -fx-padding:15 30; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
            <Label text="GAMBATTA ADMIN" style="-fx-font-size:20px; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Separator orientation="VERTICAL" prefHeight="30" style="-fx-opacity: 0.2;"/>
            
            <Button text="📦 Produits" onAction="#showCrud" styleClass="btn-secondary" style="-fx-border-color:transparent;"/>
            <Button text="💰 Ventes" onAction="#showVentesCrud" styleClass="btn-secondary" style="-fx-border-color:transparent;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Button text="🚪 Déconnexion" onAction="#logout" style="-fx-background-color:rgba(239, 68, 68, 0.1); -fx-text-fill:#ef4444; -fx-border-color:#ef4444; -fx-border-radius:8; -fx-background-radius:8; -fx-padding: 8 15; -fx-font-weight:bold;"/>
        </HBox>
    </top>

    <!-- CONTENT AREA -->
    <center>
        <StackPane fx:id="mainStack" style="-fx-background-color:#0f172a;">
            <StackPane fx:id="contentArea"/>
            
            <!-- DIM OVERLAY for Stats Modal -->
            <Region fx:id="statsOverlay" style="-fx-background-color:rgba(0,0,0,0.7);" visible="false" onMouseClicked="#toggleStats"/>

            <!-- STATS MODAL (Centered, scale=0, opacity=0 by default) -->
            <StackPane fx:id="statsSidebar" alignment="CENTER" maxWidth="900" maxHeight="600" visible="false" scaleX="0.8" scaleY="0.8" opacity="0" 
                        style="-fx-background-color: #1e293b; -fx-background-radius: 25; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 30, 0, 0, 15);">
                <fx:include fx:id="statsView" source="StatsView.fxml"/>
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
