<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gambatta.tn.ui.buvette.BuvetteMainController"
            prefHeight="650" prefWidth="1100"
            stylesheets="@style.css">

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="10" style="-fx-background-color:#0f172a; -fx-padding:20;">
            <Label text=" Buvette" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:white;"/>
            <Separator/>
            <Button text=" Dashboard" prefWidth="160" onAction="#showDashboard"/>
            <Button text=" Produits CRUD" prefWidth="160" onAction="#showCrud"/>
            <Button text=" Ventes CRUD" prefWidth="160" onAction="#showVentesCrud"/>
            <Button text=" Shop / Checkout" prefWidth="160" onAction="#showShop"/>
        </VBox>
    </left>

    <!-- CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>
