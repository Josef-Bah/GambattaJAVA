<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.TeamLeaderController" prefWidth="1000" prefHeight="700" styleClass="container" stylesheets="@style.css">
    <VBox spacing="25" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

        <VBox spacing="5">
            <Label text="Recrutement — Demandes de Joueurs" styleClass="title-label"/>
            <Label text="Gérez les demandes des joueurs qui souhaitent rejoindre vos équipes." styleClass="subtitle-label"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Filtrer par équipe :" style="-fx-text-fill: white;"/>
            <ComboBox fx:id="cmbEquipe" prefWidth="250" />
            <Button text="Toutes les équipes" onAction="#showAll" styleClass="btn-outline"/>
        </HBox>

        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>

                <TableColumn fx:id="playerCol"      text="Joueur"       prefWidth="200"/>
                <TableColumn fx:id="equipeCol"      text="Équipe cible" prefWidth="200"/>
                <TableColumn fx:id="dateCol"        text="Date demande" prefWidth="150"/>
                <TableColumn fx:id="statusCol"      text="Statut"       prefWidth="100"/>
                <TableColumn fx:id="colAccepter"    text="Action"       prefWidth="110"/>
                <TableColumn fx:id="colRefuser"     text="Action"       prefWidth="110"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
</AnchorPane>
