<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gambatta.tn.ui.EditUserPopupController"
           prefWidth="860.0"
           prefHeight="560.0"
           stylesheets="@style.css"
           styleClass="auth-root">

    <children>
        <VBox maxWidth="800.0"
              prefWidth="800.0"
              spacing="18.0"
              alignment="CENTER_LEFT">
            <padding>
                <Insets top="28.0" right="30.0" bottom="28.0" left="30.0"/>
            </padding>

            <children>
                <Label text="Modifier utilisateur" styleClass="auth-title"/>
                <Label text="Mets à jour les informations de l'utilisateur" styleClass="auth-subtitle"/>

                <HBox spacing="26.0" alignment="TOP_CENTER">
                    <children>

                        <VBox spacing="12.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Prénom" styleClass="auth-label"/>
                                        <TextField fx:id="firstNameField"
                                                   styleClass="auth-field"
                                                   prefWidth="320.0"
                                                   maxWidth="320.0"/>
                                        <Label fx:id="firstNameErrorLabel" text="" styleClass="field-help"/>
                                    </children>
                                </VBox>

                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Nom" styleClass="auth-label"/>
                                        <TextField fx:id="lastNameField"
                                                   styleClass="auth-field"
                                                   prefWidth="320.0"
                                                   maxWidth="320.0"/>
                                        <Label fx:id="lastNameErrorLabel" text="" styleClass="field-help"/>
                                    </children>
                                </VBox>

                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Email" styleClass="auth-label"/>
                                        <TextField fx:id="emailField"
                                                   styleClass="auth-field"
                                                   prefWidth="320.0"
                                                   maxWidth="320.0"/>
                                        <Label fx:id="emailErrorLabel" text="" styleClass="field-help"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="12.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Mot de passe" styleClass="auth-label"/>
                                        <PasswordField fx:id="passwordField"
                                                       styleClass="auth-field"
                                                       prefWidth="320.0"
                                                       maxWidth="320.0"/>
                                        <Label fx:id="passwordErrorLabel" text="" styleClass="field-help"/>
                                    </children>
                                </VBox>

                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Téléphone" styleClass="auth-label"/>
                                        <TextField fx:id="numTelField"
                                                   styleClass="auth-field"
                                                   prefWidth="320.0"
                                                   maxWidth="320.0"/>
                                        <Label fx:id="numTelErrorLabel" text="" styleClass="field-help"/>
                                    </children>
                                </VBox>

                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Rôle" styleClass="auth-label"/>
                                        <ComboBox fx:id="roleComboBox"
                                                  prefWidth="320.0"
                                                  maxWidth="320.0"/>
                                        <Label fx:id="roleErrorLabel" text="" styleClass="field-help"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <Label fx:id="feedbackLabel" text="" styleClass="auth-error"/>

                <HBox spacing="14.0" alignment="CENTER">
                    <children>
                        <Button text="Enregistrer"
                                onAction="#handleSave"
                                styleClass="auth-btn"
                                prefWidth="210.0"/>

                        <Button text="Annuler"
                                onAction="#handleCancel"
                                styleClass="btn-secondary"
                                prefWidth="170.0"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>