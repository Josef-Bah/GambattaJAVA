<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gambatta.tn.controllers.TournoiController">

    <!-- Champs de saisie -->
    <TextField fx:id="nomField" promptText="Nom tournoi" />
    <TextField fx:id="descField" promptText="Description" />
    <ComboBox fx:id="cmbStatut" promptText="Statut" prefWidth="200"/>

    <!-- Boutons -->
    <HBox spacing="10">
        <Button text="Ajouter / Modifier" onAction="#addTournoi" />
        <Button fx:id="btnPDF" text="Exporter PDF"/>
        <Button text="Equipe" onAction="#openEquipeWindow" />
    </HBox>

    <!-- TableView -->
    <TableView fx:id="table" prefHeight="400" prefWidth="500">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
            <TableColumn fx:id="nomCol" text="Nom" prefWidth="200"/>
            <TableColumn fx:id="statutCol" text="Statut" prefWidth="100"/>
            <TableColumn fx:id="colModifier" text="Modifier" prefWidth="100"/>
            <TableColumn fx:id="colSupprimer" text="Supprimer" prefWidth="100"/>
        </columns>
    </TableView>

</VBox>