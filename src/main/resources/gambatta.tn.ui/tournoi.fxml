<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gambatta.tn.ui.TournoiController"
            styleClass="container" stylesheets="@style.css">

    <!-- ══ HEADER ══ -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT"
              style="-fx-background-color: #0a192f; -fx-padding: 15 30; -fx-border-color: #C5B358; -fx-border-width: 0 0 2 0;">
            <Button text="← Retour" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #C5B358; -fx-border-color: #C5B358; -fx-border-width: 1px; -fx-border-radius: 8; -fx-cursor: hand;"/>
            <Label text="🏆  Gestion des Tournois"
                   style="-fx-text-fill: #C5B358; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnPDF" text="⬇ Exporter PDF" styleClass="btn-outline"/>
            <Button text="📊 Stats" onAction="#showStats" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <center>
        <HBox>
            <!-- ── DRAWER FORM ── -->
            <VBox fx:id="drawerPanel"
                  style="-fx-background-color: #0d1b2a; -fx-border-color: #C5B358; -fx-border-width: 0 2 0 0;"
                  prefWidth="0" managed="false" visible="false">

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0;">
                    <VBox spacing="16" style="-fx-padding: 25;">

                        <Label fx:id="drawerTitle" text="➕ Nouveau Tournoi"
                               style="-fx-text-fill: #C5B358; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                        <VBox spacing="5">
                            <Label text="Nom du tournoi *" style="-fx-text-fill: white;"/>
                            <TextField fx:id="nomField" promptText="Ex: Coupe Gambatta 2025" styleClass="text-field"/>
                            <Label fx:id="errNom" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Description" style="-fx-text-fill: white;"/>
                            <TextArea fx:id="descField" promptText="Décrivez le tournoi..." prefRowCount="3"
                                      styleClass="text-field" wrapText="true"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Statut *" style="-fx-text-fill: white;"/>
                            <ComboBox fx:id="cmbStatut" prefWidth="Infinity" maxWidth="Infinity" styleClass="text-field"/>
                            <Label fx:id="errStatut" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Date de début *" style="-fx-text-fill: white;"/>
                            <DatePicker fx:id="dateDebutPicker" prefWidth="Infinity" maxWidth="Infinity" styleClass="text-field"/>
                            <Label fx:id="errDateDebut" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Date de fin *" style="-fx-text-fill: white;"/>
                            <DatePicker fx:id="dateFinPicker" prefWidth="Infinity" maxWidth="Infinity" styleClass="text-field"/>
                            <Label fx:id="errDateFin" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                            <Button text="💾 Enregistrer" onAction="#addTournoi" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="✖" onAction="#closeDrawer" styleClass="btn-outline" style="-fx-min-width: 40;"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- ── TABLE ── -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-padding: 25;">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="+ Nouveau Tournoi" onAction="#openDrawerNew" styleClass="btn-primary"
                            style="-fx-font-size: 14px; -fx-padding: 12 24;"/>
                </HBox>

                <TableView fx:id="table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol"       text="ID"          prefWidth="55"/>
                        <TableColumn fx:id="nomCol"      text="Tournoi"     prefWidth="200"/>
                        <TableColumn fx:id="dateDebutCol" text="Début"      prefWidth="110"/>
                        <TableColumn fx:id="dateFinCol"   text="Fin"        prefWidth="110"/>
                        <TableColumn fx:id="statutCol"    text="Statut"     prefWidth="110"/>
                        <TableColumn fx:id="colModifier"  text="✏ Modifier" prefWidth="110"/>
                        <TableColumn fx:id="colSupprimer" text="🗑 Supprimer" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </HBox>
    </center>
</BorderPane>