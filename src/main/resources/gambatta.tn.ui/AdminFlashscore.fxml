<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.AdminFlashscoreController" prefWidth="1000" prefHeight="700" styleClass="container" stylesheets="@style.css">
    <VBox spacing="25" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Générateur de Matchs &amp; Flashscore Admin" styleClass="title-label"/>
                <Label text="Créez manuellement ou avec l'IA les rencontres pour un tournoi." styleClass="subtitle-label"/>
            </VBox>
            <ComboBox fx:id="cmbTournoi" promptText="Choisir un tournoi" prefWidth="250" />
            <Button text="Générer Matchs (IA)" onAction="#genererMatchsIA" styleClass="btn-primary"/>
            <Button text="Simuler Scores (IA)" onAction="#simulerScoresIA" styleClass="btn-secondary"/>
        </HBox>

        <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>

                <TableColumn fx:id="equipeACol" text="Équipe Domicile" prefWidth="180" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;"/>
                <TableColumn fx:id="scoreACol" text="Score" prefWidth="70" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                <TableColumn fx:id="scoreBCol" text="Score" prefWidth="70" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                <TableColumn fx:id="equipeBCol" text="Équipe Extérieure" prefWidth="180" style="-fx-alignment: CENTER-LEFT; -fx-font-weight: bold;"/>
                <TableColumn fx:id="dateCol" text="Date du Match" prefWidth="150" style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <Label fx:id="globalMsg" text="" wrapText="true" maxWidth="Infinity" style="-fx-alignment: center; -fx-padding: 0 0 10 0;"/>

        <HBox spacing="15" alignment="CENTER" styleClass="card">
            <Label text="Saisie Manuelle (Match sélectionné) :" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <TextField fx:id="txtScoreA" promptText="Score A" prefWidth="80" styleClass="text-field"/>
            <Label text="-" style="-fx-text-fill: -fx-gold; -fx-font-weight: bold; -fx-font-size: 18px;"/>
            <TextField fx:id="txtScoreB" promptText="Score B" prefWidth="80" styleClass="text-field"/>
            <HBox spacing="10">
                <Button text="Enregistrer Score" onAction="#enregistrerScore" styleClass="btn-primary" prefWidth="150"/>
                <Button text="Supprimer Match" onAction="#supprimerMatch" styleClass="btn-secondary" style="-fx-border-color: #ef4444; -fx-text-fill: #ef4444;" prefWidth="150"/>
            </HBox>
        </HBox>
    </VBox>
</AnchorPane>
