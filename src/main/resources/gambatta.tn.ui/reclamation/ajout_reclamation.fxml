<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox maxWidth="400.0" prefWidth="400.0" prefHeight="800.0" spacing="20" style="-fx-base: #0f172a; -fx-background-color: rgba(15, 23, 42, 0.95); -fx-border-color: #0ea5e9; -fx-border-width: 0 0 0 2; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 25, 0, -5, 0);"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gambatta.tn.ui.reclamation.AjoutController">

    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <VBox spacing="5" style="-fx-border-color: transparent transparent rgba(14, 165, 233, 0.3) transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
            <Label text="[ TRANSMISSION AU SUPPORT ]" style="-fx-text-fill: #0ea5e9; -fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold;" />
            <Label text="NOUVEAU TICKET" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900; -fx-font-family: 'Segoe UI Black';" />
        </VBox>

        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <VBox spacing="20" style="-fx-padding: 5 5 20 0;">

                <VBox spacing="8">
                    <Label text="&gt; OBJET DE LA REQUÊTE" style="-fx-text-fill: #94a3b8; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    <TextField fx:id="txtTitre" promptText="Ex: Problème de connexion..." style="-fx-background-color: rgba(2, 6, 23, 0.5); -fx-text-fill: white; -fx-prompt-text-fill: #475569; -fx-font-weight: bold; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
                    <Label fx:id="lblErrorTitre" visible="false" managed="false" style="-fx-text-fill: #ef4444; -fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold;" />
                </VBox>

                <VBox spacing="8">
                    <Label text="&gt; SERVICE CIBLE" style="-fx-text-fill: #94a3b8; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    <ComboBox fx:id="comboCategorie" promptText="Sélectionnez..." maxWidth="Infinity" style="-fx-background-color: rgba(2, 6, 23, 0.5); -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;" />
                    <Label fx:id="lblErrorCategorie" visible="false" managed="false" style="-fx-text-fill: #ef4444; -fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold;" />
                </VBox>

                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="&gt; DÉTAILS (PAYLOAD)" style="-fx-text-fill: #94a3b8; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="✨ IA" onAction="#handleAmeliorerIA" style="-fx-background-color: transparent; -fx-text-fill: #fbbf24; -fx-border-color: #fbbf24; -fx-border-width: 1; -fx-border-radius: 5; -fx-font-family: 'Consolas', monospace; -fx-font-size: 9px; -fx-cursor: hand; -fx-padding: 2 6;" />
                    </HBox>
                    <TextArea fx:id="txtDescription" promptText="Décrivez l'anomalie en détail..." prefHeight="150" wrapText="true" style="-fx-control-inner-background: rgba(2, 6, 23, 0.5); -fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #475569; -fx-font-size: 12px; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;" />
                    <Label fx:id="lblErrorDescription" visible="false" managed="false" style="-fx-text-fill: #ef4444; -fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold;" />
                </VBox>

                <VBox spacing="8">
                    <Label text="&gt; PREUVE VISUELLE" style="-fx-text-fill: #94a3b8; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    <VBox alignment="CENTER" spacing="10" style="-fx-border-color: rgba(255,255,255,0.1); -fx-border-style: dashed; -fx-border-radius: 8; -fx-padding: 15; -fx-background-color: rgba(2, 6, 23, 0.3);">
                        <Button text="📂 IMPORTER FICHIER" onAction="#handleChoisirFichier" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" />
                        <Label fx:id="lblCheminFichier" text="[ AUCUN FICHIER ]" style="-fx-text-fill: #64748b; -fx-font-family: 'Consolas', monospace; -fx-font-size: 10px;" textAlignment="CENTER" wrapText="true" />
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>

        <VBox spacing="10">
            <Label fx:id="lblSystemError" alignment="CENTER" maxWidth="Infinity" visible="false" managed="false" style="-fx-background-color: rgba(239, 68, 68, 0.2); -fx-text-fill: #ef4444; -fx-border-color: #ef4444; -fx-border-radius: 5; -fx-padding: 8; -fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold;" />

            <HBox spacing="10">
                <Button text="ANNULER" onAction="#handleAnnuler" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #ef4444; -fx-text-fill: #ef4444; -fx-font-weight: 900; -fx-border-radius: 8; -fx-padding: 12; -fx-cursor: hand;" />
                <Button text="ENVOYER" onAction="#handleValider" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #0ea5e9; -fx-text-fill: #020617; -fx-font-weight: 900; -fx-border-radius: 8; -fx-padding: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(14,165,233,0.4), 10, 0, 0, 0);" />
            </HBox>
        </VBox>

    </children>
</VBox>