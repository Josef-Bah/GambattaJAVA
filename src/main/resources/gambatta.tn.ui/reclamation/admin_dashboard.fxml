<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.chart.PieChart?>
<?import java.net.URL?>

<StackPane fx:id="mainRoot" prefWidth="1200.0" prefHeight="800.0" style="-fx-base: #0f172a; -fx-background-color: #020617; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="[http://javafx.com/javafx/21](http://javafx.com/javafx/21)" xmlns:fx="[http://javafx.com/fxml/1](http://javafx.com/fxml/1)" fx:controller="gambatta.tn.ui.reclamation.AdminDashboardController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <children>
        <Pane mouseTransparent="true" style="-fx-background-color: linear-gradient(from 0px 0px to 30px 30px, reflect, rgba(56, 189, 248, 0.03) 1px, transparent 1px);" />
        <Pane mouseTransparent="true" style="-fx-background-color: radial-gradient(center 50% 50%, radius 70%, rgba(14, 165, 233, 0.06) 0%, transparent 100%);" />

        <BorderPane style="-fx-padding: 30;">
            <top>
                <VBox spacing="15" style="-fx-padding: 0 0 20 0; -fx-border-color: transparent transparent rgba(56, 189, 248, 0.1) transparent; -fx-border-width: 0 0 1 0;">
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Circle radius="4" fill="#10b981" style="-fx-effect: dropshadow(gaussian, rgba(16,185,129,0.8), 8, 0, 0, 0);" />
                            <Label text="SYSTÈME OPÉRATIONNEL" style="-fx-text-fill: #10b981; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="GAMBATTA_CORE // V.2.0" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-letter-spacing: 2px;" />
                            <Button text="[ DÉCONNEXION ]" onAction="#handleLogout" style="-fx-background-color: rgba(239, 68, 68, 0.1); -fx-border-color: #ef4444; -fx-text-fill: #ef4444; -fx-background-radius: 15; -fx-border-radius: 15; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6 18;" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="25">
                            <VBox spacing="2" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to bottom right, #fcc033, #f59e0b); -fx-background-radius: 15; -fx-padding: 15 35; -fx-effect: dropshadow(gaussian, rgba(245, 158, 11, 0.4), 15, 0, 0, 0);">
                                <Label text="COMMAND" style="-fx-text-fill: #020617; -fx-font-size: 26px; -fx-font-weight: 900; -fx-letter-spacing: 1px;" />
                                <Label text="CENTRE DE RÉCLAMATIONS" style="-fx-text-fill: rgba(2, 6, 23, 0.7); -fx-font-size: 10px; -fx-font-weight: 900;" />
                            </VBox>

                            <Region HBox.hgrow="ALWAYS" />

                            <Button text="[ EXPORTER PDF ]" onAction="#handleExporterRapportGlobal" style="-fx-background-color: transparent; -fx-border-color: #f43f5e; -fx-text-fill: #f43f5e; -fx-font-weight: 900; -fx-font-size: 11px; -fx-border-radius: 20; -fx-padding: 8 15; -fx-cursor: hand;" />
                            <Button text="[ AUTO-TRIAGE ]" onAction="#handleAutoTriage" style="-fx-background-color: transparent; -fx-border-color: #fcc033; -fx-text-fill: #fcc033; -fx-font-weight: bold; -fx-font-size: 11px; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 8 15;" />
                            <Button fx:id="btnToggleCopilot" text="[ COPILOT IA ]" onAction="#toggleCopilot" style="-fx-background-color: rgba(16, 185, 129, 0.1); -fx-border-color: #10b981; -fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 11px; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 8 15;" />

                            <HBox alignment="CENTER_LEFT" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: rgba(56, 189, 248, 0.4); -fx-border-width: 1.5; -fx-border-radius: 25; -fx-background-radius: 25; -fx-padding: 6 6 6 20; -fx-effect: dropshadow(gaussian, rgba(14, 165, 233, 0.15), 15, 0, 0, 0);">
                                <Label text="SCAN_FLUX &gt; " style="-fx-text-fill: #38bdf8; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 13px;" />
                                <TextField fx:id="searchField" promptText="Rechercher un log, un ID..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                                <Button text="SYNC" onAction="#chargerTableau" style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" />
                            </HBox>
                        </HBox>

                        <HBox fx:id="boxCopilot" visible="false" managed="false" alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: rgba(16, 185, 129, 0.05); -fx-border-color: #10b981; -fx-border-radius: 8; -fx-padding: 10 20;">
                            <Label text="TERMINAL_COPILOT &gt; " style="-fx-text-fill: #10b981; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 12px;" />
                            <TextField fx:id="txtGlobalCopilot" promptText="Ex: 'Affiche-moi uniquement les tickets en attente du Service Technique' ou 'Fais un auto-triage'" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-text-fill: #10b981; -fx-prompt-text-fill: rgba(16, 185, 129, 0.5); -fx-font-family: 'Consolas', monospace; -fx-font-size: 13px;" onAction="#handleExecuterCopilotGlobal" />
                            <Button text="[ EXECUTER ]" onAction="#handleExecuterCopilotGlobal" style="-fx-background-color: transparent; -fx-border-color: #10b981; -fx-text-fill: #10b981; -fx-font-weight: bold; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 6 12;" />
                        </HBox>

                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="FILTRER_PAR :" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" />

                            <fx:define>
                                <ToggleGroup fx:id="filterGroup" />
                            </fx:define>
                            <ToggleButton fx:id="btnTous" text="TOUS LES LOGS" toggleGroup="$filterGroup" selected="true" style="-fx-background-color: rgba(14, 165, 233, 0.2); -fx-border-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 6 20; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand;" />
                            <ToggleButton fx:id="btnAttente" text="EN ATTENTE" toggleGroup="$filterGroup" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: rgba(245, 158, 11, 0.3); -fx-text-fill: #f59e0b; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 6 20; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand;" />
                            <ToggleButton fx:id="btnResolu" text="RÉSOLUS" toggleGroup="$filterGroup" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: rgba(16, 185, 129, 0.3); -fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 6 20; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand;" />

                            <Region HBox.hgrow="ALWAYS" />

                            <ComboBox fx:id="comboTri" promptText="TRIER PAR..." prefWidth="180" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: #fcc033; -fx-background-radius: 20; -fx-border-radius: 20; -fx-text-fill: white; -fx-font-size: 11px;" />
                            <ComboBox fx:id="comboModule" promptText="SÉLECTION_MODULE" prefWidth="200" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: #334155; -fx-background-radius: 20; -fx-border-radius: 20; -fx-text-fill: white; -fx-font-size: 11px;" />
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <ScrollPane fx:id="cyberScroll" fitToWidth="true" style="-fx-background: #020617; -fx-background-color: transparent;" BorderPane.alignment="CENTER">
                    <content>
                        <FlowPane fx:id="cardsContainer" hgap="30" vgap="30" style="-fx-background-color: transparent; -fx-padding: 10 20 20 5;" />
                    </content>
                </ScrollPane>
            </center>

            <right>
                <VBox spacing="15" prefWidth="350" BorderPane.alignment="CENTER" style="-fx-background-color: rgba(15, 23, 42, 0.6); -fx-border-color: rgba(56, 189, 248, 0.2); -fx-border-width: 1.5; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 25; -fx-margin: 0 0 0 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0);">

                    <Label text="&gt; ANALYSE_SYSTÈME" style="-fx-text-fill: #fcc033; -fx-font-family: 'Consolas', monospace; -fx-font-size: 16px; -fx-font-weight: 900;" />

                    <VBox spacing="5" VBox.vgrow="ALWAYS" style="-fx-background-color: rgba(30, 41, 59, 0.4); -fx-border-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 10;">
                        <Label text="[ RÉPARTITION PAR STATUT ]" style="-fx-text-fill: #0ea5e9; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px;" />
                        <PieChart fx:id="pieChartStatut" legendSide="BOTTOM" labelsVisible="false" prefHeight="220" />
                    </VBox>

                    <VBox spacing="5" VBox.vgrow="ALWAYS" style="-fx-background-color: rgba(30, 41, 59, 0.4); -fx-border-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 10;">
                        <Label text="[ RÉPARTITION PAR MODULE ]" style="-fx-text-fill: #10b981; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px;" />
                        <PieChart fx:id="pieChartModule" legendSide="BOTTOM" labelsVisible="false" prefHeight="220" />
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
                    <Label fx:id="lblTotalInfo" text="TOTAL TICKETS : 0" style="-fx-text-fill: #64748b; -fx-font-family: 'Consolas', monospace; -fx-font-size: 12px; -fx-alignment: center;" maxWidth="Infinity" />
                </VBox>
            </right>
        </BorderPane>

        <StackPane fx:id="overlayContainer" visible="false" style="-fx-background-color: rgba(2, 6, 23, 0.85);" />

    </children>
</StackPane>