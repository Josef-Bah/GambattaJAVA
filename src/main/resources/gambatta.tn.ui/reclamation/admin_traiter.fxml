<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane prefWidth="1050.0" prefHeight="700.0" style="-fx-base: #0f172a; -fx-background-color: #020617; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.reclamation.AdminTraiterController">

    <children>
        <Pane mouseTransparent="true" style="-fx-background-color: linear-gradient(from 0px 0px to 30px 30px, reflect, rgba(56, 189, 248, 0.03) 1px, transparent 1px);" />
        <Pane mouseTransparent="true" style="-fx-background-color: radial-gradient(center 50% 50%, radius 70%, rgba(14, 165, 233, 0.06) 0%, transparent 100%);" />

        <HBox spacing="25" style="-fx-padding: 30;">

            <VBox prefWidth="320.0" spacing="25" style="-fx-background-color: rgba(15, 23, 42, 0.7); -fx-padding: 25; -fx-background-radius: 20; -fx-border-color: rgba(56, 189, 248, 0.3); -fx-border-radius: 20; -fx-border-width: 1.5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 15, 0, 0, 0);">

                <VBox spacing="5">
                    <Label text="[ CONTRÔLE_TACTIQUE ]" style="-fx-text-fill: #38bdf8; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 11px;" />
                    <Label fx:id="lblRef" style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 24px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 5, 0, 0, 0);" text="#REF-000" />
                </VBox>

                <Separator style="-fx-background-color: rgba(255,255,255,0.05);" />

                <VBox spacing="10" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 15; -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 15;">
                    <Label text="&gt; 1. ÉTAT DU TICKET" style="-fx-text-fill: #fcc033; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 11px;" />
                    <ComboBox fx:id="comboStatut" maxWidth="Infinity" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: #334155; -fx-background-radius: 15; -fx-border-radius: 15; -fx-text-fill: white; -fx-font-size: 12px;" />
                    <Button fx:id="btnUpdateStatut" text="METTRE À JOUR L'ÉTAT" onAction="#handleChangerStatut" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #0ea5e9; -fx-text-fill: #0ea5e9; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 8; -fx-cursor: hand;" />
                </VBox>

                <VBox spacing="10" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 15; -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 15;">
                    <Label text="&gt; 2. ASSIGNER AU DÉPARTEMENT" style="-fx-text-fill: #fcc033; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 11px;" />
                    <ComboBox fx:id="comboAssignation" maxWidth="Infinity" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: #334155; -fx-background-radius: 15; -fx-border-radius: 15; -fx-text-fill: white; -fx-font-size: 12px;" />
                    <Button fx:id="btnAssigner" text="CONFIRMER ASSIGNATION" onAction="#handleAssigner" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #f59e0b; -fx-text-fill: #f59e0b; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 8; -fx-cursor: hand;" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="btnFermer" text="FERMER LE TERMINAL" onAction="#handleAnnuler" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #ef4444; -fx-text-fill: #ef4444; -fx-font-weight: 900; -fx-font-family: 'Consolas', monospace; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-width: 2; -fx-padding: 12; -fx-cursor: hand;" />
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="15" style="-fx-background-color: rgba(15, 23, 42, 0.7); -fx-padding: 25; -fx-background-radius: 20; -fx-border-color: rgba(56, 189, 248, 0.3); -fx-border-radius: 20; -fx-border-width: 1.5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 15, 0, 0, 0);">

                <Label text="[ CANAL_COMMUNICATION : ADMIN &lt;-&gt; CLIENT ]" style="-fx-text-fill: #38bdf8; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 11px;" />

                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="vboxHistorique" spacing="15" style="-fx-padding: 10 20 10 5; -fx-background-color: transparent;" />
                </ScrollPane>

                <VBox spacing="15" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 15;">

                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="&gt; SAISIE_MANUELLE :" style="-fx-text-fill: #fcc033; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 11px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="comboSaisieRapide" promptText="⚡ MACROS RAPIDES..." prefWidth="220.0" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: #0ea5e9; -fx-background-radius: 15; -fx-border-radius: 15; -fx-text-fill: white; -fx-font-size: 11px;" />
                        <Button fx:id="btnAmeliorer" text="✨ AMÉLIORER (IA)" onAction="#handleAmeliorerTexte" style="-fx-background-color: transparent; -fx-border-color: #10b981; -fx-text-fill: #10b981; -fx-font-weight: bold; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 5 15; -fx-font-size: 10px; -fx-cursor: hand;" />
                    </HBox>

                    <TextArea fx:id="txtReponse" promptText="Écrivez votre transmission ici..." wrapText="true" prefHeight="100.0" style="-fx-control-inner-background: rgba(15, 23, 42, 0.8); -fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-border-color: #38bdf8; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px;" />

                    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
                        <Button fx:id="btnReponseInteractive" text="RÉPONDRE (MAINTENIR OUVERT)" onAction="#handleReponseInteractive" style="-fx-background-color: transparent; -fx-border-color: #f59e0b; -fx-text-fill: #f59e0b; -fx-font-weight: 900; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10 20; -fx-cursor: hand;" />
                        <Button fx:id="btnReponseUnique" text="RÉPONDRE &amp; CLÔTURER TICKET" onAction="#handleReponseUnique" style="-fx-background-color: #38bdf8; -fx-border-color: #38bdf8; -fx-text-fill: #020617; -fx-font-weight: 900; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10 20; -fx-cursor: hand;" />
                    </HBox>
                </VBox>
            </VBox>

        </HBox>
    </children>
</StackPane>