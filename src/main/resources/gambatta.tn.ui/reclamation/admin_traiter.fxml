<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox prefWidth="900.0" prefHeight="650.0" spacing="20" style="-fx-background-color: #020617; -fx-padding: 20; -fx-border-color: #38bdf8; -fx-border-width: 1;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.reclamation.AdminTraiterController">
    <children>

        <VBox prefWidth="300.0" spacing="25" style="-fx-background-color: #0f172a; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #1e293b;">
            <Label text="GESTION DU TICKET" style="-fx-text-fill: #38bdf8; -fx-font-weight: 900; -fx-letter-spacing: 1px;" />
            <Label fx:id="lblRef" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" text="#REF-000" />

            <Separator opacity="0.1" />

            <VBox spacing="10">
                <Label text="1. ÉTAT DU TICKET" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" />
                <ComboBox fx:id="comboStatut" maxWidth="Infinity" style="-fx-background-color: #1e293b; -fx-text-fill: white;" />
                <Button text="METTRE À JOUR L'ÉTAT" onAction="#handleChangerStatut" maxWidth="Infinity" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-cursor: hand;" />
            </VBox>

            <Separator opacity="0.1" />

            <VBox spacing="10">
                <Label text="2. ASSIGNER AU DÉPARTEMENT" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" />
                <ComboBox fx:id="comboAssignation" maxWidth="Infinity" style="-fx-background-color: #1e293b; -fx-text-fill: white;" />
                <Button text="CONFIRMER L'ASSIGNATION" onAction="#handleAssigner" maxWidth="Infinity" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-cursor: hand;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            <Button text="FERMER LA FENÊTRE" onAction="#handleAnnuler" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #ef4444; -fx-text-fill: #ef4444; -fx-cursor: hand;" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="15" style="-fx-background-color: #0f172a; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #1e293b;">
            <Label text="FIL DE DISCUSSION (ADMIN &lt;-&gt; CLIENT)" style="-fx-text-fill: #38bdf8; -fx-font-weight: 900; -fx-letter-spacing: 1px;" />

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox fx:id="vboxHistorique" spacing="10" style="-fx-padding: 10;" />
            </ScrollPane>

            <Separator opacity="0.1" />

            <VBox spacing="10">
                <Label text="NOUVEAU MESSAGE :" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 11px;" />

                <TextArea fx:id="txtReponse" promptText="Écrivez votre réponse au client ici..." wrapText="true" prefHeight="100.0" style="-fx-control-inner-background: #1e293b; -fx-text-fill: white; -fx-border-color: #334155; -fx-font-family: 'Consolas';" />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="comboSaisieRapide" promptText="⚡ Saisie rapide..." prefWidth="200.0" style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-border-color: #334155;" />
                    <Button text="✨ Améliorer le texte" onAction="#handleAmeliorerTexte" style="-fx-background-color: transparent; -fx-border-color: #38bdf8; -fx-text-fill: #38bdf8; -fx-cursor: hand; -fx-border-radius: 4;" />
                </HBox>

                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button text="RÉPONSE INTERACTIVE (Garder ouvert)" onAction="#handleReponseInteractive" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15; -fx-cursor: hand;" />
                    <Button text="RÉPONSE UNIQUE (Clôturer le ticket)" onAction="#handleReponseUnique" style="-fx-background-color: #38bdf8; -fx-text-fill: #020617; -fx-font-weight: bold; -fx-padding: 10 15; -fx-cursor: hand;" />
                </HBox>
            </VBox>
        </VBox>

    </children>
</HBox>