<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.effect.*?>

<StackPane prefWidth="600.0" prefHeight="700.0" style="-fx-base: #0f172a; -fx-background-color: #020617; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.reclamation.AdminVoirController">

    <children>
        <Pane mouseTransparent="true" style="-fx-background-color: linear-gradient(from 0px 0px to 30px 30px, reflect, rgba(56, 189, 248, 0.03) 1px, transparent 1px);" />
        <Pane mouseTransparent="true" style="-fx-background-color: radial-gradient(center 50% 50%, radius 70%, rgba(14, 165, 233, 0.08) 0%, transparent 100%);" />

        <VBox spacing="20" style="-fx-padding: 25;">

            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-border-color: transparent transparent rgba(56, 189, 248, 0.2) transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                <VBox spacing="2">
                    <Label text="[ DOSSIER_RÉCLAMATION ]" style="-fx-text-fill: #38bdf8; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 10px;" />
                    <Label fx:id="lblTitre" text="TITRE DU TICKET" wrapText="true" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 5, 0, 0, 0);" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblSentiment" text="ANALYSE..." style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 11px; -fx-padding: 6 15; -fx-background-radius: 20; -fx-border-radius: 20; -fx-background-color: rgba(100, 116, 139, 0.5);" />
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(30, 41, 59, 0.6); -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-padding: 10;">
                    <Label text="ÉMETTEUR" style="-fx-text-fill: #64748b; -fx-font-size: 9px; -fx-font-weight: bold; -fx-font-family: 'Consolas', monospace;" />
                    <Label fx:id="lblAuteur" text="Inconnu" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" />
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(30, 41, 59, 0.6); -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-padding: 10;">
                    <Label text="DATE" style="-fx-text-fill: #64748b; -fx-font-size: 9px; -fx-font-weight: bold; -fx-font-family: 'Consolas', monospace;" />
                    <Label fx:id="lblDate" text="--/--/----" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12px;" />
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(30, 41, 59, 0.6); -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-padding: 10;">
                    <Label text="MODULE" style="-fx-text-fill: #64748b; -fx-font-size: 9px; -fx-font-weight: bold; -fx-font-family: 'Consolas', monospace;" />
                    <Label fx:id="lblCategorie" text="Non classé" style="-fx-text-fill: #38bdf8; -fx-font-size: 12px; -fx-font-weight: bold;" />
                </VBox>
                <VBox alignment="CENTER" spacing="2" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(30, 41, 59, 0.6); -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-padding: 10;">
                    <Label text="STATUT" style="-fx-text-fill: #64748b; -fx-font-size: 9px; -fx-font-weight: bold; -fx-font-family: 'Consolas', monospace;" />
                    <Label fx:id="lblStatut" text="En attente" style="-fx-text-fill: #f59e0b; -fx-font-size: 12px; -fx-font-weight: 900;" />
                </VBox>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="20" style="-fx-padding: 5 10 10 5;">

                    <VBox spacing="8">
                        <Label text="&gt; DESCRIPTION DU PROBLÈME" style="-fx-text-fill: #fcc033; -fx-font-weight: 900; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px;" />
                        <Label fx:id="lblDescription" wrapText="true" style="-fx-text-fill: #f8fafc; -fx-background-color: rgba(15, 23, 42, 0.8); -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: rgba(56, 189, 248, 0.3); -fx-border-radius: 10; -fx-border-width: 1.5; -fx-font-size: 13px; -fx-line-spacing: 4;" />
                    </VBox>

                    <VBox spacing="8">
                        <Label text="&gt; PREUVE VISUELLE (SCAN)" style="-fx-text-fill: #fcc033; -fx-font-weight: 900; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px;" />
                        <StackPane alignment="CENTER" style="-fx-background-color: rgba(15, 23, 42, 0.6); -fx-padding: 10; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-style: dashed; -fx-max-height: 220;">
                            <ImageView fx:id="imgPreuve" fitWidth="350.0" fitHeight="200.0" preserveRatio="true" />
                            <Label fx:id="lblNoImage" text="[ AUCUNE PIÈCE JOINTE DÉTECTÉE ]" style="-fx-text-fill: #64748b; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 11px;" visible="false" />
                        </StackPane>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="&gt; HISTORIQUE DES COMMUNICATIONS" style="-fx-text-fill: #fcc033; -fx-font-weight: 900; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px;" />
                        <VBox fx:id="vboxHistorique" spacing="10" style="-fx-background-color: transparent;" />
                    </VBox>

                </VBox>
            </ScrollPane>

            <HBox alignment="CENTER">
                <Button fx:id="btnClose" text="FERMER LE TERMINAL" onAction="#handleFermer" style="-fx-background-color: transparent; -fx-border-color: #ef4444; -fx-text-fill: #ef4444; -fx-font-weight: 900; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-padding: 10 25; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-width: 2; -fx-cursor: hand;" />
            </HBox>

        </VBox>
    </children>
</StackPane>