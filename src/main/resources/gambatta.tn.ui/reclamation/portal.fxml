<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import java.net.URL?>

<StackPane prefWidth="900.0" prefHeight="600.0" style="-fx-background-color: #0b1121; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.reclamation.PortalController">

    <Pane mouseTransparent="true" style="-fx-background-color: radial-gradient(center 50% 50%, radius 70%, rgba(14, 165, 233, 0.05) 0%, transparent 100%);" />

    <VBox alignment="CENTER" spacing="50">

        <VBox alignment="CENTER" spacing="10">
            <Label text="Bienvenue sur GAMBATTA" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: 900; -fx-effect: dropshadow(gaussian, rgba(252, 192, 51, 0.3), 15, 0, 0, 0);" />
            <Label text="Veuillez sélectionner votre espace de connexion" style="-fx-text-fill: #94a3b8; -fx-font-size: 15px;" />
        </VBox>

        <HBox alignment="CENTER" spacing="40">

            <VBox fx:id="cardClient" alignment="CENTER" spacing="20" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 40 30; -fx-pref-width: 320; -fx-pref-height: 350; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 0, 10);">

                <VBox alignment="CENTER" prefHeight="80">
                    <SVGPath content="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" fill="#38bdf8" scaleX="3.5" scaleY="3.5" />
                </VBox>

                <VBox alignment="CENTER" spacing="8" VBox.vgrow="ALWAYS">
                    <Label text="ESPACE CLIENT" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 900;" />
                    <Label text="Réserver des activités, consulter&#10;le catalogue" textAlignment="CENTER" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-line-spacing: 3;" />
                </VBox>

                <Button fx:id="btnUser" text="Connexion User" onAction="#handleUserAccess" prefWidth="250" style="-fx-background-color: linear-gradient(to bottom right, #facc15, #f59e0b); -fx-text-fill: #020617; -fx-font-weight: 900; -fx-font-size: 15px; -fx-padding: 12 0; -fx-background-radius: 10; -fx-cursor: hand;" />
            </VBox>

            <VBox fx:id="cardAdmin" alignment="CENTER" spacing="20" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 40 30; -fx-pref-width: 320; -fx-pref-height: 350; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 0, 10);">

                <VBox alignment="CENTER" prefHeight="80">
                    <SVGPath content="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,5A3,3 0 0,1 15,8A3,3 0 0,1 12,11A3,3 0 0,1 9,8A3,3 0 0,1 12,5M17.13,17C15.92,18.85 14.11,20.24 12,20.92C9.89,20.24 8.08,18.85 6.87,17C7.53,15.3 10.91,13.8 12,13.8C13.09,13.8 16.47,15.3 17.13,17Z" fill="#facc15" scaleX="3.5" scaleY="3.5" />
                </VBox>

                <VBox alignment="CENTER" spacing="8" VBox.vgrow="ALWAYS">
                    <Label text="ESPACE ADMIN" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 900;" />
                    <Label text="Gérer les activités, valider les&#10;réservations" textAlignment="CENTER" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-line-spacing: 3;" />
                </VBox>

                <Button fx:id="btnAdmin" text="Connexion Admin" onAction="#handleAdminAccess" prefWidth="250" style="-fx-background-color: transparent; -fx-border-color: #facc15; -fx-border-width: 2; -fx-border-radius: 10; -fx-text-fill: #facc15; -fx-font-weight: 900; -fx-font-size: 15px; -fx-padding: 10 0; -fx-cursor: hand;" />
            </VBox>

        </HBox>
    </VBox>
</StackPane>