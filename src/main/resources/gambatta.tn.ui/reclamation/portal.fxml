<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane prefWidth="800.0" prefHeight="500.0" style="-fx-background-color: #020617;"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gambatta.tn.ui.reclamation.PortalController">

    <stylesheets> <URL value="@../style.css" /> </stylesheets>

    <VBox alignment="CENTER" spacing="50">
        <VBox alignment="CENTER" spacing="10">
            <Label text="GAMBATTA_CORE" style="-fx-text-fill: #0ea5e9; -fx-font-size: 12px; -fx-font-weight: 900; -fx-letter-spacing: 5px;" />
            <Label text="SÉLECTION DU PROTOCOLE" styleClass="title" style="-fx-font-size: 36px;" />
        </VBox>

        <HBox alignment="CENTER" spacing="40">
            <VBox alignment="CENTER" spacing="15">
                <Button text="ACCÈS UTILISATEUR" onAction="#handleUserAccess"
                        style="-fx-background-color: #0ea5e9; -fx-text-fill: #020617; -fx-font-weight: 900; -fx-padding: 20 40; -fx-background-radius: 10;" />
                <Label text="Signaler un incident" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" />
            </VBox>

            <VBox alignment="CENTER" spacing="15">
                <Button text="ACCÈS ADMIN" onAction="#handleAdminAccess"
                        style="-fx-background-color: transparent; -fx-border-color: #10b981; -fx-border-width: 2; -fx-text-fill: #10b981; -fx-font-weight: 900; -fx-padding: 20 40; -fx-border-radius: 10;" />
                <Label text="Gérer les flux" style="-fx-text-fill: #64748b; -fx-font-size: 11px;" />
            </VBox>
        </HBox>
    </VBox>
</StackPane>