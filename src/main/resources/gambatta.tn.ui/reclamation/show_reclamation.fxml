<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.effect.*?>
<?import java.net.URL?>

<VBox maxWidth="450.0" prefWidth="450.0" prefHeight="800.0" spacing="20" style="-fx-base: #0f172a; -fx-background-color: rgba(15, 23, 42, 0.95); -fx-border-color: #0ea5e9; -fx-border-width: 0 0 0 2; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 25, 0, -5, 0);"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gambatta.tn.ui.reclamation.ShowReclamationController">

    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <VBox spacing="10" style="-fx-border-color: transparent transparent rgba(14,165,233,0.3) transparent; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 15 0;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="FILE_DECRYPTED // GAMBATTA_DB" style="-fx-text-fill: #FFD700; -fx-font-size: 10px; -fx-font-weight: 900; -fx-letter-spacing: 2px; -fx-font-family: 'Consolas';" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblId" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-family: 'Consolas'; -fx-font-size: 14px; -fx-font-weight: bold;" />
            </HBox>
            <Label fx:id="lblTitre" wrapText="true" styleClass="title" style="-fx-font-size: 22px; -fx-text-fill: white; -fx-effect: dropshadow(three-pass-box, rgba(14,165,233,0.6), 15, 0, 0, 0);" />
        </VBox>

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="50" />
            </columnConstraints>

            <VBox alignment="CENTER" spacing="2" style="-fx-background-color: rgba(30,41,59,0.7); -fx-border-color: rgba(14,165,233,0.5); -fx-border-width: 0 0 0 3; -fx-padding: 10;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="TIMESTAMP" style="-fx-text-fill: #64748b; -fx-font-size: 9px; -fx-font-family: 'Consolas';" />
                <Label fx:id="lblDate" style="-fx-text-fill: #f8fafc; -fx-font-size: 11px; -fx-font-weight: bold;" />
            </VBox>
            <VBox alignment="CENTER" spacing="2" style="-fx-background-color: rgba(30,41,59,0.7); -fx-border-color: #ef4444; -fx-border-width: 0 0 0 3; -fx-padding: 10;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="THREAT LEVEL" style="-fx-text-fill: #64748b; -fx-font-size: 9px; -fx-font-family: 'Consolas';" />
                <Label fx:id="lblUrgence" style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-font-weight: bold;" />
            </VBox>
            <VBox alignment="CENTER" spacing="2" style="-fx-background-color: rgba(30,41,59,0.7); -fx-border-color: rgba(14,165,233,0.5); -fx-border-width: 0 0 0 3; -fx-padding: 10;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="MODULE" style="-fx-text-fill: #64748b; -fx-font-size: 9px; -fx-font-family: 'Consolas';" />
                <Label fx:id="lblCategorie" style="-fx-text-fill: #0ea5e9; -fx-font-size: 11px; -fx-font-weight: bold;" />
            </VBox>
            <VBox alignment="CENTER" spacing="2" style="-fx-background-color: rgba(30,41,59,0.7); -fx-border-color: #f59e0b; -fx-border-width: 0 0 0 3; -fx-padding: 10;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="STATUT" style="-fx-text-fill: #64748b; -fx-font-size: 9px; -fx-font-family: 'Consolas';" />
                <Label fx:id="lblStatut" style="-fx-text-fill: #f59e0b; -fx-font-size: 12px; -fx-font-weight: bold;" />
            </VBox>
        </GridPane>

        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <VBox spacing="20" style="-fx-padding: 5 10 10 5;">

                <VBox style="-fx-background-color: rgba(2,6,23,0.8); -fx-border-color: rgba(14,165,233,0.2); -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 15;">
                    <Label text="&gt; DECRYPTED_USER_LOG :" style="-fx-text-fill: #0ea5e9; -fx-font-family: 'Consolas'; -fx-font-size: 11px; -fx-padding: 0 0 10 0;" />
                    <Label fx:id="lblDescription" wrapText="true" style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px; -fx-line-spacing: 5px; -fx-font-family: 'Consolas';" />
                </VBox>

                <VBox fx:id="boxPreuve" alignment="CENTER" spacing="10" style="-fx-background-color: rgba(16,185,129,0.05); -fx-border-color: #10b981; -fx-border-width: 1; -fx-border-radius: 10; -fx-padding: 15;">
                    <Label text="[ ATTACHED_MEDIA ]" style="-fx-text-fill: #10b981; -fx-font-family: 'Consolas'; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    <StackPane style="-fx-border-color: rgba(16,185,129,0.3); -fx-padding: 5; -fx-max-height: 200;">
                        <ImageView fx:id="imgPreuve" fitWidth="300" preserveRatio="true" />
                    </StackPane>
                    <Button fx:id="btnOuvrirPreuve" text="DOWNLOAD / VIEW" onAction="#handleOuvrirPreuve" style="-fx-background-color: transparent; -fx-border-color: #10b981; -fx-text-fill: #10b981; -fx-font-weight: 900; -fx-font-size: 10px; -fx-padding: 8 20; -fx-cursor: hand;" />
                </VBox>

                <VBox spacing="10">
                    <Label text="&gt; SYSTÈME DE RÉPONSES :" style="-fx-text-fill: #FFD700; -fx-font-family: 'Consolas'; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    <VBox fx:id="vboxReponses" spacing="10" style="-fx-background-color: rgba(0,0,0,0.5); -fx-border-color: rgba(255,215,0,0.3); -fx-border-width: 0 0 0 2; -fx-padding: 15;" />
                </VBox>
            </VBox>
        </ScrollPane>

        <VBox spacing="10" alignment="CENTER">
            <Label fx:id="lblTicketClos" text="[ ACCÈS_REFUSÉ : DOSSIER_CLÔTURÉ ]" visible="false" managed="false" style="-fx-text-fill: #ef4444; -fx-font-family: 'Consolas'; -fx-font-weight: bold; -fx-font-size: 11px;" />
            <Button fx:id="btnOuvrirDiscussion" text="&gt; ÉTABLIR_COMMUNICATION [LINK]" onAction="#handleOuvrirDiscussion" visible="false" managed="false" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #10b981; -fx-text-fill: #10b981; -fx-font-weight: 900; -fx-font-size: 11px; -fx-padding: 12; -fx-border-radius: 5; -fx-cursor: hand;" />
            <Button text="TERMINER L'INSPECTION [X]" onAction="#handleFermer" maxWidth="Infinity" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 11px; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;" />
        </VBox>

    </children>
</VBox>