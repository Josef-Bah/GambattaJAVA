<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<StackPane fx:id="mainRoot" prefWidth="1200.0" prefHeight="800.0" style="-fx-base: #0f172a; -fx-background-color: #020617; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.reclamation.ReclamationController">

    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <Pane mouseTransparent="true" style="-fx-background-color: linear-gradient(from 0px 0px to 30px 30px, reflect, rgba(56, 189, 248, 0.03) 1px, transparent 1px);" />
        <Pane mouseTransparent="true" style="-fx-background-color: radial-gradient(center 50% 50%, radius 70%, rgba(14, 165, 233, 0.06) 0%, transparent 100%);" />

        <VBox spacing="25" style="-fx-padding: 30;">

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-border-color: transparent transparent rgba(56, 189, 248, 0.1) transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                <Circle radius="4" fill="#10b981" style="-fx-effect: dropshadow(gaussian, rgba(16,185,129,0.8), 8, 0, 0, 0);" />
                <Label text="SYSTEM_STATUS: ONLINE" style="-fx-text-fill: #10b981; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 2px;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="GAMBATTA_PROTOCOL_v2.0" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 11px; -fx-font-family: 'Consolas', monospace; -fx-letter-spacing: 1px;" />
                <Button text="DÉCONNEXION" onAction="#handleLogout" style="-fx-background-color: rgba(239, 68, 68, 0.1); -fx-border-color: #ef4444; -fx-text-fill: #ef4444; -fx-background-radius: 15; -fx-border-radius: 15; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 5 15;" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="25">
                <VBox spacing="2" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to bottom right, #fcc033, #f59e0b); -fx-background-radius: 15; -fx-padding: 15 35; -fx-effect: dropshadow(gaussian, rgba(245, 158, 11, 0.4), 15, 0, 0, 0);">
                    <Label text="ESPACE PERSONNEL" style="-fx-text-fill: #020617; -fx-font-size: 26px; -fx-font-weight: 900; -fx-letter-spacing: 1px;" />
                    <Label fx:id="lblTotalTickets" text="TOTAL : 0 TICKETS" style="-fx-text-fill: rgba(2, 6, 23, 0.7); -fx-font-size: 11px; -fx-font-weight: 900;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <Button text="📥 EXPORTER RAPPORT PDF" onAction="#handleExporterRapportGlobal" style="-fx-background-color: transparent; -fx-border-color: #f43f5e; -fx-text-fill: #f43f5e; -fx-font-weight: 900; -fx-font-size: 12px; -fx-border-radius: 20; -fx-padding: 10 20; -fx-cursor: hand;" />

                <Button text="+ NOUVEAU TICKET" onAction="#handleAjouter" style="-fx-background-color: #0ea5e9; -fx-text-fill: #020617; -fx-font-weight: 900; -fx-font-size: 14px; -fx-background-radius: 20; -fx-padding: 12 30; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(14, 165, 233, 0.5), 15, 0, 0, 0);" />
            </HBox>

            <VBox spacing="15" style="-fx-background-color: rgba(15, 23, 42, 0.6); -fx-background-radius: 15; -fx-border-color: rgba(14, 165, 233, 0.2); -fx-border-radius: 15; -fx-border-width: 1.5; -fx-padding: 20;">

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="RECHERCHE :" style="-fx-text-fill: #94a3b8; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 11px;" />
                    <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(2, 6, 23, 0.8); -fx-border-color: rgba(56, 189, 248, 0.4); -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 5 15;">
                        <Label text="🔍" style="-fx-text-fill: #38bdf8;" />
                        <TextField fx:id="searchField" promptText="Rechercher par Titre ou ID..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Button text="📊 ANALYSE" onAction="#handleAfficherStats" style="-fx-background-color: transparent; -fx-border-color: #a855f7; -fx-text-fill: #a855f7; -fx-font-weight: bold; -fx-border-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" />

                    <Button text="RAFRAÎCHIR" onAction="#chargerTableau" style="-fx-background-color: transparent; -fx-border-color: #38bdf8; -fx-text-fill: #38bdf8; -fx-font-weight: bold; -fx-border-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="FILTRER ET TRIER :" style="-fx-text-fill: #94a3b8; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 11px;" />

                    <fx:define>
                        <ToggleGroup fx:id="filterGroup" />
                    </fx:define>

                    <ToggleButton fx:id="btnTous" text="TOUS (0)" toggleGroup="$filterGroup" selected="true" style="-fx-background-color: rgba(14, 165, 233, 0.2); -fx-border-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 6 15; -fx-font-size: 11px; -fx-cursor: hand;" />
                    <ToggleButton fx:id="btnAttente" text="EN ATTENTE (0)" toggleGroup="$filterGroup" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: rgba(245, 158, 11, 0.4); -fx-text-fill: #f59e0b; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 6 15; -fx-font-size: 11px; -fx-cursor: hand;" />
                    <ToggleButton fx:id="btnResolu" text="RÉSOLUS (0)" toggleGroup="$filterGroup" style="-fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-color: rgba(16, 185, 129, 0.4); -fx-text-fill: #10b981; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 6 15; -fx-font-size: 11px; -fx-cursor: hand;" />

                    <Region HBox.hgrow="ALWAYS" />

                    <ComboBox fx:id="comboTri" promptText="TRIER PAR..." prefWidth="180" style="-fx-background-color: rgba(2, 6, 23, 0.8); -fx-border-color: #fcc033; -fx-background-radius: 15; -fx-border-radius: 15; -fx-text-fill: white; -fx-font-size: 11px;" />
                    <ComboBox fx:id="comboModule" promptText="SÉLECTION MODULE..." prefWidth="180" style="-fx-background-color: rgba(2, 6, 23, 0.8); -fx-border-color: #334155; -fx-background-radius: 15; -fx-border-radius: 15; -fx-text-fill: white; -fx-font-size: 11px;" />
                </HBox>
            </VBox>

            <ScrollPane fx:id="cyberScroll" fitToWidth="true" style="-fx-background: #020617; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <content>
                    <FlowPane fx:id="cardsContainer" hgap="25" vgap="25" style="-fx-background-color: transparent; -fx-padding: 10 10 20 5;" />
                </content>
            </ScrollPane>
        </VBox>

        <StackPane fx:id="overlayContainer" visible="false" style="-fx-background-color: rgba(2, 6, 23, 0.85);" />

    </children>
</StackPane>