<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox maxWidth="400.0" prefWidth="400.0" prefHeight="800.0" spacing="15" style="-fx-base: #0f172a; -fx-background-color: rgba(15, 23, 42, 0.95); -fx-border-color: #38bdf8; -fx-border-width: 0 0 0 2; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 25, 0, -5, 0);"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gambatta.tn.ui.reclamation.ClientChatController">

    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <VBox spacing="5" style="-fx-border-color: transparent transparent rgba(56, 189, 248, 0.3) transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
            <Label text="[ CANAL_COMMUNICATION_SÉCURISÉ ]" style="-fx-text-fill: #38bdf8; -fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="TERMINAL CHAT" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900; -fx-font-family: 'Segoe UI Black';" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTicketId" style="-fx-text-fill: #64748b; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-font-size: 12px;" text="#ID" />
            </HBox>
        </VBox>

        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <VBox fx:id="vboxChat" spacing="15" style="-fx-padding: 5 10 15 0;" />
        </ScrollPane>

        <VBox spacing="10" style="-fx-background-color: rgba(30,41,59,0.5); -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: rgba(56,189,248,0.2); -fx-border-radius: 10;">
            <Label text="&gt; ENTRÉE DES DONNÉES :" style="-fx-text-fill: #38bdf8; -fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-font-weight: bold;" />

            <TextArea fx:id="txtMessage" prefHeight="90.0" promptText="Rédigez votre transmission ici..." wrapText="true" style="-fx-control-inner-background: rgba(2,6,23,0.8); -fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 5; -fx-font-family: 'Consolas', monospace; -fx-font-size: 12px; -fx-padding: 5;" />

            <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
                <Button text="FERMER" onAction="#handleFermer" style="-fx-background-color: transparent; -fx-border-color: #ef4444; -fx-text-fill: #ef4444; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 8 15;" />
                <Button text="TRANSMETTRE" onAction="#handleEnvoyer" style="-fx-background-color: #38bdf8; -fx-text-fill: #020617; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 8 20; -fx-effect: dropshadow(gaussian, rgba(56,189,248,0.4), 10, 0, 0, 0);" />
            </HBox>
        </VBox>
    </children>
</VBox>