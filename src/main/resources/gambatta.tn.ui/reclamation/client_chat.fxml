<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="500.0" prefHeight="600.0" spacing="15" style="-fx-background-color: #020617; -fx-padding: 20; -fx-border-color: #38bdf8; -fx-border-width: 1;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.reclamation.ClientChatController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="&gt; TERMINAL_COMMUNICATION" style="-fx-text-fill: #38bdf8; -fx-font-family: 'Consolas'; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblTicketId" style="-fx-text-fill: #64748b; -fx-font-family: 'Consolas';" text="#ID" />
        </HBox>

        <Separator opacity="0.2" />

        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <VBox fx:id="vboxChat" spacing="15" style="-fx-padding: 10;">
            </VBox>
        </ScrollPane>

        <Separator opacity="0.2" />

        <VBox spacing="10">
            <Label text="VOTRE RÉPONSE :" style="-fx-text-fill: #38bdf8; -fx-font-family: 'Consolas'; -fx-font-size: 10px;" />
            <TextArea fx:id="txtMessage" prefHeight="80.0" promptText="Tapez votre message ici..." wrapText="true" style="-fx-control-inner-background: #0f172a; -fx-text-fill: white; -fx-border-color: #1e293b; -fx-font-family: 'Consolas';" />

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="ANNULER" onAction="#handleFermer" style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-family: 'Consolas'; -fx-cursor: hand;" />
                <Button text="TRANSMETTRE_MESSAGE" onAction="#handleEnvoyer" style="-fx-background-color: #38bdf8; -fx-text-fill: #020617; -fx-font-family: 'Consolas'; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </children>
</VBox>