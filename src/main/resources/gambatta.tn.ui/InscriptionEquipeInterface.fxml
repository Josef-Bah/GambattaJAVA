<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="gambatta.tn.controllers.InscriptionController"
            prefWidth="1000" prefHeight="700" styleClass="container" stylesheets="@style.css">
            
    <VBox spacing="40" AnchorPane.topAnchor="40" AnchorPane.leftAnchor="40" AnchorPane.rightAnchor="40" alignment="TOP_CENTER">
        
        <VBox spacing="10" alignment="CENTER">
            <Label text="PRÊT POUR L'AVENTURE ?" styleClass="title-label" />
            <Label text="Choisissez comment vous souhaitez intégrer la compétition." styleClass="subtitle-label" />
        </VBox>

        <HBox spacing="30" alignment="CENTER">
            <!-- Rejoindre un tournoi -->
            <VBox spacing="20" styleClass="card" prefWidth="300" style="-fx-padding: 30;">
                <Label text="Rejoindre un Tournoi" style="-fx-font-weight:bold; -fx-font-size:18; -fx-text-fill: -fx-primary-color;" />
                <Label text="Intégrez un groupe déjà formé et participez à un tournoi actif en tant que coéquipier." wrapText="true" style="-fx-text-fill: -fx-text-muted;" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="btnTrouverTournoi" text="TROUVER UN TOURNOI" styleClass="btn-secondary" maxWidth="Infinity" />
            </VBox>

            <!-- Créer son équipe -->
            <VBox spacing="20" styleClass="card" prefWidth="300" style="-fx-padding: 30;">
                <Label text="Créer mon équipe" style="-fx-font-weight:bold; -fx-font-size:18; -fx-text-fill: -fx-primary-color;" />
                <Label text="Devenez capitaine, choisissez votre nom et vos couleurs, puis invitez vos amis." wrapText="true" style="-fx-text-fill: -fx-text-muted;" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="btnLancerCreation" text="LANCER LA CRÉATION" onAction="#handleLancerCreation" styleClass="btn-primary" maxWidth="Infinity" />
            </VBox>

            <!-- Rejoindre une équipe existante -->
            <VBox spacing="20" styleClass="card" prefWidth="300" style="-fx-padding: 30;">
                <Label text="Joueur individuel" style="-fx-font-weight:bold; -fx-font-size:18; -fx-text-fill: -fx-primary-color;" />
                <Label text="Envoyez une demande rapide pour intégrer une équipe existante." wrapText="true" style="-fx-text-fill: -fx-text-muted;" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="btnOuvrirRejoindre" text="REJOINDRE UNE ÉQUIPE" onAction="#handleRejoindreEquipe" styleClass="btn-secondary" maxWidth="Infinity" />
            </VBox>
        </HBox>
        
        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 40 0 0 0;">
             <Button text="← RETOUR À L'ACCUEIL" styleClass="btn-outline" />
        </HBox>
    </VBox>
</AnchorPane>