<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gambatta.tn.ui.InscriptionController"
            styleClass="container" stylesheets="@style.css">

    <!-- ══ HEADER ══ -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT"
              style="-fx-background-color: #0a192f; -fx-padding: 15 30; -fx-border-color: #C5B358; -fx-border-width: 0 0 2 0;">
            <Button text="← Retour" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #C5B358; -fx-border-color: #C5B358; -fx-border-width: 1px; -fx-border-radius: 8; -fx-cursor: hand;"/>
            <Label text="🎮  Rejoindre l'Aventure"
                   style="-fx-text-fill: #C5B358; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <VBox spacing="40" alignment="CENTER" style="-fx-padding: 60;">

            <VBox spacing="10" alignment="CENTER">
                <Label text="PRÊT POUR L'AVENTURE ?" styleClass="title-label"/>
                <Label text="Choisissez comment vous souhaitez intégrer la compétition." styleClass="subtitle-label"/>
            </VBox>

            <HBox spacing="30" alignment="CENTER">

                <!-- Card 1: Créer son équipe -->
                <VBox spacing="20" styleClass="card" prefWidth="320" prefHeight="250" style="-fx-padding: 35;">
                    <Label text="🏆" style="-fx-font-size: 36px;"/>
                    <Label text="Créer mon Équipe" style="-fx-font-weight:bold; -fx-font-size:18; -fx-text-fill: #C5B358;"/>
                    <Label text="Devenez capitaine, choisissez votre nom et invitez vos amis à vous rejoindre."
                           wrapText="true" style="-fx-text-fill: #8892b0;"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button text="LANCER LA CRÉATION" onAction="#handleLancerCreation"
                            styleClass="btn-primary" maxWidth="Infinity"/>
                </VBox>

                <!-- Card 2: Rejoindre une équipe -->
                <VBox spacing="20" styleClass="card" prefWidth="320" prefHeight="250" style="-fx-padding: 35;">
                    <Label text="👥" style="-fx-font-size: 36px;"/>
                    <Label text="Rejoindre une Équipe" style="-fx-font-weight:bold; -fx-font-size:18; -fx-text-fill: #C5B358;"/>
                    <Label text="Envoyez une demande pour intégrer une équipe existante en tant que joueur."
                           wrapText="true" style="-fx-text-fill: #8892b0;"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button text="REJOINDRE UNE ÉQUIPE" onAction="#handleRejoindreEquipe"
                            styleClass="btn-secondary" maxWidth="Infinity"/>
                </VBox>

                <!-- Card 3: Trouver un tournoi -->
                <VBox spacing="20" styleClass="card" prefWidth="320" prefHeight="250" style="-fx-padding: 35;">
                    <Label text="⚡" style="-fx-font-size: 36px;"/>
                    <Label text="Trouver un Tournoi" style="-fx-font-weight:bold; -fx-font-size:18; -fx-text-fill: #C5B358;"/>
                    <Label text="Consultez les tournois disponibles et inscrivez votre équipe à la compétition."
                           wrapText="true" style="-fx-text-fill: #8892b0;"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button fx:id="btnTrouverTournoi" text="VOIR LES TOURNOIS"
                            styleClass="btn-outline" maxWidth="Infinity"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>