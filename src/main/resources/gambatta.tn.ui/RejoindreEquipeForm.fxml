<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gambatta.tn.ui.RejoindreEquipeController"
            styleClass="container" stylesheets="@style.css">

    <!-- ══ HEADER ══ -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT"
              style="-fx-background-color: #000133; -fx-padding: 15 30; -fx-border-color: #C5B358; -fx-border-width: 0 0 2 0;">
            <Button text="← Retour" onAction="#handleRetour"
                    style="-fx-background-color: transparent; -fx-text-fill: #C5B358; -fx-border-color: #C5B358; -fx-border-width: 1px; -fx-border-radius: 8; -fx-cursor: hand;"/>
            <Label text="👥  Rejoindre une Équipe"
                   style="-fx-text-fill: #C5B358; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <VBox spacing="40" alignment="CENTER" style="-fx-padding: 60;">

            <VBox spacing="8" alignment="CENTER">
                <Label text="REJOINDRE UNE ÉQUIPE" styleClass="title-label"/>
                <Label text="Trouvez vos futurs coéquipiers et préparez-vous pour l'action." styleClass="subtitle-label"/>
            </VBox>

            <VBox spacing="20" maxWidth="520" styleClass="card" style="-fx-padding: 45;">

                <VBox spacing="6">
                    <Label text="VOTRE NOM COMPLET *" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                    <TextField fx:id="txtPlayerName" promptText="Entrez votre nom" styleClass="text-field"/>
                    <Label fx:id="errPlayerName" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="CHOISIR UNE ÉQUIPE *" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                    <ComboBox fx:id="comboEquipeSelection" promptText="Sélectionner une équipe..."
                              maxWidth="Infinity" styleClass="text-field"/>
                    <Label fx:id="errEquipe" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                </VBox>

                <Button text="📩 ENVOYER MA DEMANDE" onAction="#handleEnvoyerDemande"
                        maxWidth="Infinity" styleClass="btn-primary"
                        style="-fx-padding: 15; -fx-font-size: 15px;"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
