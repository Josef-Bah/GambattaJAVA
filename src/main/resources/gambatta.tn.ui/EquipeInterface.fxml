<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="gambatta.tn.ui.EquipeController"
            prefWidth="1000" prefHeight="700" styleClass="container" stylesheets="@style.css">

    <VBox spacing="25" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">
        
        <VBox spacing="5">
            <Label text="Gestion des Équipes" styleClass="title-label"/>
            <Label text="Administrez les équipes et gérez les participants." styleClass="subtitle-label"/>
        </VBox>

        <VBox spacing="20" styleClass="card" style="-fx-padding: 20;">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch" promptText="Rechercher par nom..." prefWidth="300"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnTournoi" text="VOIR TOURNOIS" styleClass="btn-secondary"/>
                <Button fx:id="btnPDF" text="EXPORTER PDF" styleClass="btn-outline"/>
                <Button text="STATS" onAction="#showStats" styleClass="btn-secondary"/>
                <Button fx:id="btnNouvelleEquipe" text="+ NOUVELLE ÉQUIPE" styleClass="btn-primary"/>
            </HBox>
        </VBox>

        <TableView fx:id="tableEquipes" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colNom" text="Nom de l'Équipe" prefWidth="250"/>
                <TableColumn fx:id="colLeader" text="Leader" prefWidth="250"/>
                <TableColumn fx:id="colStatus" text="Statut" prefWidth="120"/>
                <TableColumn fx:id="colModifier" text="Modifier" prefWidth="110"/>
                <TableColumn fx:id="colSupprimer" text="Supprimer" prefWidth="110"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

    </VBox>
</AnchorPane>