<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<!-- EquipeInterface : Layout "Drawer" Gold & Navy -->
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gambatta.tn.ui.EquipeController"
            styleClass="container" stylesheets="@style.css">

    <!-- ═══════════════ HEADER TOP BAR ═══════════════ -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT"
              style="-fx-background-color: #000133; -fx-padding: 15 30; -fx-border-color: #C5B358; -fx-border-width: 0 0 2 0;">
            <Button text="← Retour" onAction="#goBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #C5B358; -fx-border-color: #C5B358; -fx-border-width: 1px; -fx-border-radius: 8; -fx-cursor: hand;"/>
            <Label text="👥  Gestion des Équipes"
                   style="-fx-text-fill: #C5B358; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtSearch" promptText="🔍  Rechercher par nom..."
                       prefWidth="280" styleClass="text-field"/>
            <Button fx:id="btnPDF" text="CLOUD PDF" styleClass="btn-outline"/>
            <Button text="📊 Stats" onAction="#showStats" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
    <center>
        <HBox>

            <!-- ─── DRAWER FORM (Left panel, toggled) ─── -->
            <VBox fx:id="drawerPanel"
                  style="-fx-background-color: #010203; -fx-border-color: #C5B358; -fx-border-width: 0 2 0 0;"
                  prefWidth="0" managed="false" visible="false">

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0;">
                    <VBox spacing="16" style="-fx-padding: 25;">

                        <Label fx:id="drawerTitle" text="➕  Nouvelle Équipe"
                               style="-fx-text-fill: #C5B358; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                        <VBox spacing="5">
                            <Label text="Nom de l'équipe *" style="-fx-text-fill: white;"/>
                            <TextField fx:id="drawerNom" promptText="Ex: Les Aigles" styleClass="text-field"/>
                            <Label fx:id="errNom" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Capitaine / Team Leader *" style="-fx-text-fill: white;"/>
                            <TextField fx:id="drawerLeader" promptText="Ex: Ahmed Ben Ali" styleClass="text-field"/>
                            <Label fx:id="errLeader" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Coach" style="-fx-text-fill: white;"/>
                            <TextField fx:id="drawerCoach" promptText="Ex: Coach Mehdi" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Logo de l'équipe *" style="-fx-text-fill: white;"/>
                            <HBox spacing="8">
                                <TextField fx:id="drawerLogo" promptText="URL du logo..." styleClass="text-field" HBox.hgrow="ALWAYS"/>
                                <Button text="☁ Upload" onAction="#handleUploadLogo"
                                        style="-fx-background-color: #000133; -fx-text-fill: #C5B358; -fx-border-color: #C5B358; -fx-border-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                            </HBox>
                            <Label fx:id="errLogo" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                            
                            <!-- Aperçu de l'image -->
                            <StackPane prefHeight="120" maxWidth="120" style="-fx-background-color: #000133; -fx-border-color: #C5B358; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1;">
                                <ImageView fx:id="logoPreview" fitWidth="110" fitHeight="110" preserveRatio="true"/>
                            </StackPane>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Statut" style="-fx-text-fill: white;"/>
                            <ComboBox fx:id="drawerStatut" prefWidth="Infinity" maxWidth="Infinity" styleClass="text-field"/>
                            <Label fx:id="errStatut" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Titres / Palmarès" style="-fx-text-fill: white;"/>
                            <TextField fx:id="drawerTitres" promptText="Ex: Coupe 2023" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Objectifs" style="-fx-text-fill: white;"/>
                            <TextArea fx:id="drawerObjectifs" promptText="Décrivez les objectifs..." prefRowCount="3"
                                      styleClass="text-field" wrapText="true"/>
                        </VBox>

                        <Label fx:id="globalMsg" text="" wrapText="true" maxWidth="Infinity" style="-fx-padding: 0 0 10 0;"/>

                        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                            <Button text="💾 Enregistrer" onAction="#saveFromDrawer" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="✖" onAction="#closeDrawer" styleClass="btn-outline" style="-fx-min-width: 40;"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- ─── TABLE MAIN AREA ─── -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-padding: 25;">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="+ Nouvelle Équipe" onAction="#openDrawerNew"
                            styleClass="btn-primary"
                            style="-fx-font-size: 14px; -fx-padding: 12 24;"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <FlowPane fx:id="cardsContainer" hgap="25" vgap="25" style="-fx-padding: 10;">
                        <!-- Les cartes d'équipes seront ajoutées ici dynamiquement -->
                    </FlowPane>
                </ScrollPane>
            </VBox>

        </HBox>
    </center>

</BorderPane>
