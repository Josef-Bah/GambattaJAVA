<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gambatta.tn.ui.CreationEquipeController"
            styleClass="container" stylesheets="@style.css">

    <!-- ══ HEADER ══ -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT"
              style="-fx-background-color: #000133; -fx-padding: 15 30; -fx-border-color: #C5B358; -fx-border-width: 0 0 2 0;">
            <Button text="← Retour" onAction="#handleAnnuler"
                    style="-fx-background-color: transparent; -fx-text-fill: #C5B358; -fx-border-color: #C5B358; -fx-border-width: 1px; -fx-border-radius: 8; -fx-cursor: hand;"/>
            <Label text="🏅  Créer mon Équipe"
                   style="-fx-text-fill: #C5B358; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="30" style="-fx-padding: 40 120; -fx-alignment: top-center;">

                <VBox spacing="6" alignment="CENTER">
                    <Label text="CRÉEZ VOTRE ÉQUIPE" styleClass="title-label"/>
                    <Label text="Donnez une identité unique à votre futur club." styleClass="subtitle-label"/>
                </VBox>

                <VBox spacing="20" styleClass="card" style="-fx-padding: 40;">

                    <GridPane hgap="30" vgap="5">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <!-- Nom -->
                        <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="NOM DE L'ÉQUIPE *" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                            <TextField fx:id="txtNom" promptText="Ex: Les Lions du Désert" styleClass="text-field"/>
                            <Label fx:id="errNom" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <!-- Capitaine -->
                        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="CAPITAINE *" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                            <TextField fx:id="txtLeader" promptText="Votre nom complet" styleClass="text-field"/>
                            <Label fx:id="errLeader" text="" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>
                        </VBox>

                        <!-- Coach -->
                        <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="COACH" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                            <TextField fx:id="txtCoach" promptText="Nom de l'entraîneur (optionnel)" styleClass="text-field"/>
                        </VBox>

                        <!-- Logo -->
                        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="LOGO" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                            <HBox spacing="10">
                                <TextField fx:id="txtLogo" promptText="URL du logo" HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                <Button text="🎨 IA" onAction="#handleGenerateLogoIA" styleClass="btn-secondary"/>
                            </HBox>
                        </VBox>

                        <!-- IA Panel -->
                        <VBox fx:id="vboxGenIA" spacing="8" GridPane.columnSpan="2" GridPane.rowIndex="2" managed="false" visible="false">
                            <Label text="DESCRIPTION POUR LA GÉNÉRATION IA" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                            <HBox spacing="10">
                                <TextField fx:id="txtPromptLogo" promptText="Ex: Un lion féroce avec couronne, or et bleu marine" HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                <Button fx:id="btnGenLogo" text="🤖 GÉNÉRER" onAction="#handleDoGenerateLogo" styleClass="btn-primary"/>
                            </HBox>
                        </VBox>

                        <!-- Titres -->
                        <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="3">
                            <Label text="TITRES &amp; PALMARÈS" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                            <TextField fx:id="txtTitres" promptText="Ex: Champion 2023, Finaliste 2024..." styleClass="text-field"/>
                        </VBox>

                        <!-- Objectifs -->
                        <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="4">
                            <Label text="OBJECTIFS DE L'ÉQUIPE" style="-fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                            <TextArea fx:id="txtObjectifs" promptText="Décrivez l'ambition de votre équipe..." prefRowCount="4"
                                      styleClass="text-field" wrapText="true"/>
                        </VBox>
                    </GridPane>

                    <Label fx:id="globalMsg" text="" wrapText="true" maxWidth="Infinity" style="-fx-padding: 0 0 10 0;"/>

                    <!-- Boutons -->
                    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                        <Button text="✖ Annuler" onAction="#handleAnnuler" styleClass="btn-outline" style="-fx-padding: 12 25;"/>
                        <Button text="💾 Enregistrer l'Équipe" onAction="#handleSave" styleClass="btn-primary" style="-fx-padding: 12 30; -fx-font-size: 14px;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
