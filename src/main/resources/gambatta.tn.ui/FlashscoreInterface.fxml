<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.FlashscoreController" prefWidth="1200" prefHeight="800" style="-fx-background-color: #010203;" stylesheets="@style.css">
    
    <VBox spacing="20" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
        
        <!-- Header Charcoal & Red -->
        <HBox alignment="CENTER" style="-fx-background-color: #000133; -fx-padding: 20; -fx-border-color: #C5B358; -fx-border-width: 0 0 3 0;">
            <Label text="⚡ GAMBATTA LIVESCORE" style="-fx-text-fill: #C5B358; -fx-font-size: 32px; -fx-font-weight: bold;"/>
        </HBox>

        <VBox spacing="10" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Sélectionnez un tournoi :" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                <ComboBox fx:id="cmbTournoi" prefWidth="300" styleClass="text-field"/>
                <Button text="🔄 Actualiser" onAction="#actualiser" styleClass="btn-secondary"/>
            </HBox>

            <TabPane VBox.vgrow="ALWAYS" styleClass="view-tabs">
                <Tab text="Arbre du Tournoi (IA)" closable="false">
                    <ScrollPane fitToHeight="true" vbarPolicy="NEVER">
                        <HBox fx:id="bracketPane" spacing="60" alignment="CENTER_LEFT" style="-fx-padding: 40 20;"/>
                    </ScrollPane>
                </Tab>
                <Tab text="Liste des Matchs" closable="false">
                    <TableView fx:id="table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="dateCol" text="Date &amp; Heure" prefWidth="150" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="equipeACol" text="Equipe Domicile" prefWidth="250" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;"/>
                            <TableColumn fx:id="scoreCol" text="Score" prefWidth="150" style="-fx-alignment: CENTER; -fx-font-size: 18px; -fx-text-fill: #C5B358; -fx-font-weight: bold;"/>
                            <TableColumn fx:id="equipeBCol" text="Equipe Ext\u00e9rieure" prefWidth="250" style="-fx-alignment: CENTER-LEFT; -fx-font-weight: bold;"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </Tab>
                <Tab text="Classement" closable="false">
                    <TableView fx:id="standingsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="teamCol" text="Equipe" prefWidth="250"/>
                            <TableColumn fx:id="playedCol" text="MJ" prefWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="wonCol" text="G" prefWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="drawnCol" text="N" prefWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="lostCol" text="P" prefWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="gfCol" text="BP" prefWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="gaCol" text="BC" prefWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="gdCol" text="+/-" prefWidth="60" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="ptsCol" text="PTS" prefWidth="80" style="-fx-alignment: CENTER; -fx-font-weight: bold; -fx-text-fill: #C5B358;"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </Tab>
            </TabPane>
        </VBox>
    </VBox>
</AnchorPane>
