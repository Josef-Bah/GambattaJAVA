<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="gambatta.tn.ui.InscritournoiController"
            prefWidth="1000" prefHeight="700" styleClass="container" stylesheets="@style.css">

    <VBox spacing="25" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">
        
        <VBox spacing="5">
            <Label text="Inscriptions aux Tournois" styleClass="title-label"/>
            <Label text="Gérez les participations des équipes aux différents tournois." styleClass="subtitle-label"/>
        </VBox>

        <VBox spacing="20" styleClass="card" style="-fx-padding: 20;">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <ComboBox fx:id="comboEquipe" promptText="Choisir une équipe" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <ComboBox fx:id="comboTournoi" promptText="Choisir un tournoi" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="btnAjouter" text="INSCRIRE L'ÉQUIPE" styleClass="btn-primary"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch" promptText="Rechercher par équipe ou tournoi..." HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnPDF" text="EXPORTER PDF" styleClass="btn-outline"/>
                <Button fx:id="btnStats" text="VOIR STATS" styleClass="btn-secondary"/>
                <Button fx:id="btnSupprimer" text="RETIRER" styleClass="btn-danger"/>
            </HBox>
        </VBox>

        <TableView fx:id="tableInscriptions" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colEquipe" text="Nom de l'Équipe" prefWidth="250"/>
                <TableColumn fx:id="colTournoi" text="Nom du Tournoi" prefWidth="250"/>
                <TableColumn fx:id="colStatus" text="Statut de l'Inscription" prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

    </VBox>
</AnchorPane>