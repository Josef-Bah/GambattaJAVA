<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="gambatta.tn.ui.AdminDashboardController" stylesheets="@style.css" prefWidth="1280" prefHeight="800">
    <left>
        <VBox spacing="15" style="-fx-background-color: #000133; -fx-padding: 30; -fx-min-width: 250;">
            <Label text="G A M B A T T A" style="-fx-text-fill: #C5B358; -fx-font-size: 24px; -fx-font-weight: bold; -fx-padding: 0 0 30 0;"/>
            <Label text="ADMIN PANEL" style="-fx-text-fill: #8892b0; -fx-font-size: 14px; -fx-padding: 0 0 10 0;"/>
            
            <Button text="🏆 Gestion Tournois" onAction="#loadTournois" styleClass="btn-secondary" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-font-size: 14px; -fx-padding: 10 20;"/>
            <Button text="🛡️ Validation Équipes" onAction="#loadValidation" styleClass="btn-secondary" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-font-size: 14px; -fx-padding: 10 20;"/>
            <Button text="✅ Validation Inscriptions" onAction="#loadInscriptions" styleClass="btn-secondary" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-font-size: 14px; -fx-padding: 10 20;"/>
            <Button text="⚡ Flashscore &amp; Matchs" onAction="#loadFlashscore" styleClass="btn-secondary" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-font-size: 14px; -fx-padding: 10 20;"/>
            <Button text="👤 Recrutement Équipes" onAction="#loadTeamLeader" styleClass="btn-secondary" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-font-size: 14px; -fx-padding: 10 20;"/>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button text="🏠 Déconnexion" onAction="#goHome" styleClass="btn-outline" maxWidth="Infinity" alignment="CENTER"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f4f4f4;"/>
    </center>
</BorderPane>
