<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gambatta.tn.ui.AdminDashboardController"
            prefWidth="1280.0" prefHeight="760.0"
            stylesheets="@style.css"
            styleClass="root">

    <!-- ══════════════════ SIDEBAR ══════════════════ -->
    <left>
        <VBox styleClass="sidebar-classic" spacing="18.0">
            <padding>
                <Insets top="26.0" right="18.0" bottom="26.0" left="18.0"/>
            </padding>
            <children>
                <Label text="GAMBATTA" styleClass="sidebar-brand"/>
                <Label text="Backoffice Admin" styleClass="sidebar-subtitle"/>

                <Separator/>

                <VBox spacing="8.0">
                    <children>
                        <Label text="Navigation" styleClass="sidebar-section-title"/>
                        <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="sidebar-item-active">
                            <children>
                                <Label text="👥" styleClass="sidebar-item-icon"/>
                                <Label text="Utilisateurs" styleClass="sidebar-item-text-active"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Pane VBox.vgrow="ALWAYS"/>

                <Separator/>

                <VBox spacing="10.0">
                    <children>
                        <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="sidebar-bottom-item">
                            <children>
                                <Label text="👤" styleClass="sidebar-item-icon"/>
                                <Hyperlink text="Mon compte" onAction="#openAdminProfile" styleClass="sidebar-link"/>
                            </children>
                        </HBox>
                        <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="sidebar-bottom-item">
                            <children>
                                <Label text="⇦" styleClass="sidebar-item-icon"/>
                                <Hyperlink text="Déconnexion" onAction="#logout" styleClass="sidebar-link-danger"/>
                            </children>
                        </HBox>
                        <Button text="📊  Statistiques" styleClass="btn-secondary"
                                maxWidth="Infinity" onAction="#openStats"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <!-- ══════════════════ MAIN CONTENT ══════════════════ -->
    <center>
        <VBox spacing="18.0" styleClass="admin-main-clean">
            <padding>
                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
            </padding>
            <children>

                <!-- Title -->
                <VBox spacing="4.0">
                    <children>
                        <Label text="Admin Dashboard" styleClass="dashboard-title-clean"/>
                        <Label fx:id="welcomeLabel" text="Bienvenue" styleClass="dashboard-subtitle-clean"/>
                    </children>
                </VBox>

                <!-- Stats row -->
                <HBox spacing="16.0">
                    <children>
                        <VBox styleClass="stat-card-clean" HBox.hgrow="ALWAYS" spacing="6.0">
                            <children>
                                <Label text="👥 Total utilisateurs" styleClass="stat-title-clean"/>
                                <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value-clean"/>
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card-clean" HBox.hgrow="ALWAYS" spacing="6.0">
                            <children>
                                <Label text="⭐ Admins" styleClass="stat-title-clean"/>
                                <Label fx:id="totalAdminsLabel" text="0" styleClass="stat-value-clean"/>
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card-clean" HBox.hgrow="ALWAYS" spacing="6.0">
                            <children>
                                <Label text="🟢 Actifs" styleClass="stat-title-clean"/>
                                <Label fx:id="totalActifsLabel" text="0" styleClass="stat-value-clean"/>
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card-clean" HBox.hgrow="ALWAYS" spacing="6.0">
                            <children>
                                <Label text="🔐 Connexions aujourd'hui" styleClass="stat-title-clean"/>
                                <Label fx:id="loginsTodayLabel" text="0" styleClass="stat-value-clean"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Users panel -->
                <VBox spacing="14.0" VBox.vgrow="ALWAYS" styleClass="users-panel-clean">
                    <children>

                        <!-- Header: title + search -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label text="👥 Gestion des utilisateurs" styleClass="section-title-clean"/>
                                <Pane HBox.hgrow="ALWAYS"/>
                                <TextField fx:id="searchField"
                                           promptText="Rechercher par nom, email, rôle, statut..."
                                           onKeyReleased="#handleSearch"
                                           styleClass="search-field-clean"
                                           prefWidth="360.0"/>
                            </children>
                        </HBox>

                        <Label fx:id="feedbackLabel" text="" styleClass="admin-feedback"/>

                        <!-- Cards area -->
                        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="scroll-pane"
                                    hbarPolicy="NEVER">
                            <content>
                                <FlowPane fx:id="cardsContainer"
                                          hgap="16.0" vgap="16.0"
                                          styleClass="cards-container">
                                    <padding>
                                        <Insets top="4.0" right="4.0" bottom="8.0" left="4.0"/>
                                    </padding>
                                </FlowPane>
                            </content>
                        </ScrollPane>

                    </children>
                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>
