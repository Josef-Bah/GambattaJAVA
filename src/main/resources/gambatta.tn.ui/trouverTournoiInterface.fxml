<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="gambatta.tn.ui.TrouverTournoiController"
            prefWidth="1000" prefHeight="600" styleClass="container" stylesheets="@style.css">

    <VBox spacing="40" alignment="CENTER" AnchorPane.topAnchor="60" AnchorPane.leftAnchor="100" AnchorPane.rightAnchor="100">
        
        <!-- Titre -->
        <VBox spacing="10" alignment="CENTER">
            <Label text="INSCRIPTION AU TOURNOI" styleClass="title-label"/>
            <Label text="Inscrivez votre équipe et entrez dans la légende." styleClass="subtitle-label"/>
        </VBox>

        <!-- Formulaire -->
        <VBox spacing="25" maxWidth="500" styleClass="card" style="-fx-padding: 40;">

            <VBox spacing="8">
                <Label text="ÉTAPE 1: CHOISIR VOTRE ÉQUIPE" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="comboEquipe" promptText="Sélectionner une équipe..." maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="8">
                <Label text="ÉTAPE 2: SÉLECTIONNER LE TOURNOI" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="comboTournoi" promptText="Choisir une compétition active..." maxWidth="Infinity"/>
            </VBox>

            <Button fx:id="btnEnvoyer" text="ENVOYER LA DEMANDE" styleClass="btn-primary" maxWidth="Infinity" style="-fx-padding: 15;"/>
            
            <HBox alignment="CENTER">
                <Label fx:id="lblRetour" text="← Annuler et retourner" style="-fx-cursor: hand; -fx-text-fill: -fx-text-muted;"/>
            </HBox>
        </VBox>

        <Label text="Selon le mode de l'équipe, la demande sera validée par le leader ou par l'administrateur." style="-fx-font-size: 11px; -fx-text-fill: -fx-text-muted;"/>
    </VBox>
</AnchorPane>
