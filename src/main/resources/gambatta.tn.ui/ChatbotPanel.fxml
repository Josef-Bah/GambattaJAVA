<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  Chatbot panel — loaded programmatically and injected into the HomeUser StackPane.
  The root VBox is aligned CENTER_RIGHT in the parent StackPane and starts
  off-screen (translateX = 380) until toggled by HomeUserController.toggleChatbot().
-->
<VBox fx:id="chatPanel"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gambatta.tn.ui.ChatbotPanelController"
      prefWidth="380.0"
      prefHeight="760.0"
      maxWidth="380.0"
      style="-fx-background-color: #0f172a;
             -fx-border-color: rgba(255,215,0,0.28);
             -fx-border-width: 0 0 0 1;
             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.55), 20, 0, -4, 0);">

    <!-- ══ Header ══ -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: rgba(15,23,42,0.98);
                 -fx-border-color: rgba(255,215,0,0.12);
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 16 16 16 16;">
        <children>
            <Label text="🤖"
                   style="-fx-font-size: 22px;"/>
            <VBox spacing="1" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Assistant Gambatta"
                           style="-fx-text-fill: #FFD700;
                                  -fx-font-size: 15px;
                                  -fx-font-weight: 900;"/>
                    <Label text="Disponible 24h/24"
                           style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                </children>
            </VBox>
            <Button text="✕" onAction="#close"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #64748b;
                           -fx-font-size: 18px;
                           -fx-padding: 4 8 4 8;
                           -fx-cursor: hand;"/>
        </children>
    </HBox>

    <!-- ══ Messages scroll area ══ -->
    <ScrollPane fx:id="scrollPane"
                VBox.vgrow="ALWAYS"
                fitToWidth="true"
                hbarPolicy="NEVER"
                style="-fx-background-color: transparent;
                       -fx-background: transparent;
                       -fx-border-color: transparent;">
        <content>
            <VBox fx:id="messagesBox"
                  spacing="8"
                  style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="14.0" right="12.0" bottom="14.0" left="12.0"/>
                </padding>
            </VBox>
        </content>
    </ScrollPane>

    <!-- ══ Typing indicator ══ -->
    <HBox fx:id="typingBox" visible="false"
          style="-fx-padding: 4 16 4 16;">
        <children>
            <Label text="🤖  En train d'écrire..."
                   style="-fx-text-fill: #64748b;
                          -fx-font-size: 11px;
                          -fx-font-style: italic;"/>
        </children>
    </HBox>

    <!-- ══ Input bar ══ -->
    <HBox spacing="8" alignment="CENTER"
          style="-fx-background-color: rgba(8,17,31,0.98);
                 -fx-border-color: rgba(255,215,0,0.12);
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 12 12 12 12;">
        <children>
            <TextField fx:id="inputField"
                       HBox.hgrow="ALWAYS"
                       promptText="Posez votre question..."
                       onAction="#sendMessage"
                       styleClass="search-field-clean"/>
            <Button text="⬆"
                    onAction="#sendMessage"
                    styleClass="btn-primary"
                    style="-fx-min-width: 42;
                           -fx-min-height: 42;
                           -fx-padding: 8 12 8 12;
                           -fx-font-size: 16px;
                           -fx-font-weight: 900;"/>
        </children>
    </HBox>

</VBox>
